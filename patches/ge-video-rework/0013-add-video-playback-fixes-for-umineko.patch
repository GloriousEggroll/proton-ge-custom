From b485fdd9ed4b6fedb326f161188a1a4e133edbba Mon Sep 17 00:00:00 2001
From: GloriousEggroll <gloriouseggroll@gmail.com>
Date: Wed, 17 Jun 2026 02:40:57 -0600
Subject: [PATCH] add video playback fixes for umineko

---
 dlls/qasf/dmowrapper.c        | 3 ++-
 dlls/quartz/filtergraph.c     | 5 +++++
 dlls/winedmo/unix_transform.c | 8 +++++++-
 3 files changed, 14 insertions(+), 2 deletions(-)

diff --git a/dlls/qasf/dmowrapper.c b/dlls/qasf/dmowrapper.c
index 999a2259ffa..4420f4b2721 100644
--- a/dlls/qasf/dmowrapper.c
+++ b/dlls/qasf/dmowrapper.c
@@ -492,7 +492,8 @@ static HRESULT dmo_wrapper_new_segment(struct strmbase_sink *iface,
     {
         if (filter->sources[i].pin.pin.peer)
         {
-            filter->sources[i].send_media_type = TRUE;
+            filter->sources[i].send_media_type = IsEqualGUID(&filter->sources[i].pin.pin.mt.majortype, &MEDIATYPE_Video)
+                    ? FALSE : TRUE;
             filter->sources[i].send_discontinuity = TRUE;
             if (FAILED(ret = IPin_NewSegment(filter->sources[i].pin.pin.peer, start, stop, rate))
                     && SUCCEEDED(hr))
diff --git a/dlls/quartz/filtergraph.c b/dlls/quartz/filtergraph.c
index 2de13f5d6d9..bd6729ff364 100644
--- a/dlls/quartz/filtergraph.c
+++ b/dlls/quartz/filtergraph.c
@@ -1482,6 +1482,11 @@ static HRESULT add_source_filter_with_clsid(IFilterGraph2 *iface, const WCHAR *f
         clsid = *source_clsid;
     else if (!get_media_type(filename, NULL, NULL, &clsid))
         clsid = CLSID_AsyncReader;
+    else if (IsEqualGUID(&clsid, &CLSID_WMAsfReader))
+    {
+        TRACE("Using async reader before ASF source reader for %s.\n", debugstr_w(filename));
+        clsid = CLSID_AsyncReader;
+    }
     TRACE("Using source filter %s.\n", debugstr_guid(&clsid));
 
     if (FAILED(hr = CoCreateInstance(&clsid, NULL, CLSCTX_INPROC_SERVER,
diff --git a/dlls/winedmo/unix_transform.c b/dlls/winedmo/unix_transform.c
index 490a4a78d6d..bfbc59761c2 100644
--- a/dlls/winedmo/unix_transform.c
+++ b/dlls/winedmo/unix_transform.c
@@ -516,6 +516,12 @@ static inline BOOL is_wmv_video_codec( enum AVCodecID codec_id )
     return codec_id == AV_CODEC_ID_WMV3 || codec_id == AV_CODEC_ID_VC1;
 }
 
+static inline BOOL is_wmv_parser_codec( enum AVCodecID codec_id )
+{
+    return codec_id == AV_CODEC_ID_WMV1 || codec_id == AV_CODEC_ID_WMV2
+            || is_wmv_video_codec( codec_id );
+}
+
 static UINT32 mpeg_find_picture_start( const BYTE *data, UINT32 size, UINT32 offset )
 {
     UINT32 i;
@@ -839,7 +845,7 @@ NTSTATUS transform_create( void *arg )
     }
 
     if (!t->is_audio && (codec_id == AV_CODEC_ID_MPEG1VIDEO || codec_id == AV_CODEC_ID_MPEG2VIDEO
-            || is_wmv_video_codec( codec_id )))
+            || is_wmv_parser_codec( codec_id )))
     {
         t->parser = av_parser_init( codec_id );
         t->parser_codec_id = codec_id;
-- 
2.54.0

