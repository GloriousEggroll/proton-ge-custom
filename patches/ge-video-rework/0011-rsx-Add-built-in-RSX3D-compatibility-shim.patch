+static void rsx_queue_wave_data_from_stub(IUnknown *iface, void *size_arg, void *data)
+{
+    struct rsx_object *object = impl_from_IUnknown(iface);
+    struct rsx_wave_playback playback = {0};
+    DWORD size = (DWORD)(ULONG_PTR)size_arg;
+
+    if (size > 16 * 1024 * 1024)
+        return;
+
+    if (rsx_data_is_riff_wave(data))
+    {
+        if (!rsx_parse_wave_data(data, size, &playback))
+            return;
+
+        rsx_queue_wave_data(object->shared, playback.format, playback.data, playback.size, NULL);
+        free(playback.format);
+        free(playback.data);
+    }
+    else if (object->shared->wave_format && size)
+    {
+        rsx_queue_wave_data(object->shared, object->shared->wave_format, data, size, NULL);
+    }
+}
