+static void rsx_queue_wave_data(struct rsx_shared *shared, const WAVEFORMATEX *format,
+        const void *data, DWORD size, DWORD *stream_status)
+{
+    struct rsx_wave_header *wave_header;
+    MMRESULT ret;
+
+    if (!data || !size)
+        return;
+
+    if (!shared->wave)
+    {
+        if (!(shared->wave_format = malloc(format->cbSize + sizeof(*format))))
+            return;
+
+        memcpy(shared->wave_format, format, format->cbSize + sizeof(*format));
+
+        ret = waveOutOpen(&shared->wave, WAVE_MAPPER, shared->wave_format,
+                (DWORD_PTR)rsx_wave_out_proc, (DWORD_PTR)shared, CALLBACK_FUNCTION);
+        if (ret != MMSYSERR_NOERROR)
+        {
+            WARN("waveOutOpen failed %#x.\n", ret);
+            free(shared->wave_format);
+            shared->wave_format = NULL;
+            return;
+        }
+    }
+
+    rsx_cleanup_done_wave_headers(shared);
+
+    if (!(wave_header = calloc(1, sizeof(*wave_header))))
+        return;
+
+    if (!(wave_header->header.lpData = malloc(size)))
+    {
+        free(wave_header);
+        return;
+    }
+
+    memcpy(wave_header->header.lpData, data, size);
+    wave_header->header.dwBufferLength = size;
+    wave_header->stream_status = stream_status;
+    if (stream_status)
+        *stream_status = 1;
+    if (stream_status)
+        wave_header->stream_entry = (BYTE *)stream_status - 4;
+
+    ret = waveOutPrepareHeader(shared->wave, &wave_header->header, sizeof(wave_header->header));
+    if (ret != MMSYSERR_NOERROR)
+    {
+        WARN("waveOutPrepareHeader failed %#x.\n", ret);
+        if (stream_status)
+            *stream_status = 0;
+        free(wave_header->header.lpData);
+        free(wave_header);
+        return;
+    }
+
+    ret = waveOutWrite(shared->wave, &wave_header->header, sizeof(wave_header->header));
+    if (ret != MMSYSERR_NOERROR)
+    {
+        WARN("waveOutWrite failed %#x.\n", ret);
+        waveOutUnprepareHeader(shared->wave, &wave_header->header, sizeof(wave_header->header));
+        if (stream_status)
+            *stream_status = 0;
+        free(wave_header->header.lpData);
+        free(wave_header);
+        return;
+    }
+
+    wave_header->next = shared->wave_headers;
+    shared->wave_headers = wave_header;
+}
