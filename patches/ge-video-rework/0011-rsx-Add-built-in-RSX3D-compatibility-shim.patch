+static HRESULT rsx_create(REFIID iid, void **out)
+{
+    struct rsx_object *object;
+    HRESULT hr;
+
+    if (!out) return E_POINTER;
+    *out = NULL;
+
+    if (!(object = calloc(1, sizeof(*object))))
+        return E_OUTOFMEMORY;
+
+    if (!(object->shared = rsx_shared_acquire()))
+    {
+        free(object);
+        return E_OUTOFMEMORY;
+    }
+
+    object->lpVtbl = (void *)&rsx_vtbl;
+    object->ref = 1;
+
+    hr = IUnknown_QueryInterface((IUnknown *)&object->lpVtbl, iid, out);
+    IUnknown_Release((IUnknown *)&object->lpVtbl);
+    return hr;
+}
