+static void rsx_trace_bytes(const char *prefix, const BYTE *data, DWORD size);
+static struct rsx_shared *rsx_global_shared;
+
+static void set_rsx_wave_device_key(HKEY root, const char *root_name)
+{
+    static const char key_name[] = "Software\\Intel\\Realistic Sound Experience\\2.0";
+    static const char value[] = "wave";
+    HKEY key;
+    LONG ret;
+
+    ret = RegCreateKeyA(root, key_name, &key);
+    if (ret)
+    {
+        WARN("Failed to create %s\\%s, error %ld.\n", root_name, key_name, ret);
+        return;
+    }
+
+    ret = RegSetValueExA(key, "Device Type", 0, REG_SZ, (const BYTE *)value, sizeof(value));
+    if (ret)
+        WARN("Failed to set %s\\%s Device Type, error %ld.\n", root_name, key_name, ret);
+    else
+        TRACE("Set %s\\%s Device Type to %s.\n", root_name, key_name, value);
+
+    RegCloseKey(key);
+}
+
+static void set_rsx_wave_device(void)
+{
+    set_rsx_wave_device_key(HKEY_LOCAL_MACHINE, "HKLM");
+    set_rsx_wave_device_key(HKEY_CURRENT_USER, "HKCU");
+}
+
+static struct rsx_object *impl_from_IUnknown(IUnknown *iface)
+{
+    return CONTAINING_RECORD(iface, struct rsx_object, lpVtbl);
+}
+
+static void rsx_cleanup_done_wave_headers(struct rsx_shared *shared)
+{
+    struct rsx_wave_header **entry = &shared->wave_headers;
+
+    while (*entry)
+    {
+        struct rsx_wave_header *wave_header = *entry;
+
+        if (!(wave_header->header.dwFlags & WHDR_DONE))
+        {
+            entry = &wave_header->next;
+            continue;
+        }
+
+        *entry = wave_header->next;
+        waveOutUnprepareHeader(shared->wave, &wave_header->header, sizeof(wave_header->header));
+        if (wave_header->stream_status)
+            *wave_header->stream_status = 0;
+        if (wave_header->stream_entry && !IsBadReadPtr(wave_header->stream_entry, 0x28))
+            rsx_trace_bytes("RSX completed stream header", wave_header->stream_entry, 0x28);
+        free(wave_header->header.lpData);
+        free(wave_header);
+    }
+}
+
+static void rsx_cleanup_wave_output(struct rsx_shared *shared)
+{
+    struct rsx_wave_header *wave_header, *next;
+
+    if (shared->stream_stop)
+    {
+        SetEvent(shared->stream_stop);
+        if (shared->stream_thread)
+            WaitForSingleObject(shared->stream_thread, 1000);
+        CloseHandle(shared->stream_stop);
+        shared->stream_stop = NULL;
+    }
+    if (shared->stream_thread)
+    {
+        CloseHandle(shared->stream_thread);
+        shared->stream_thread = NULL;
+    }
+
+    if (shared->wave)
+        waveOutReset(shared->wave);
+
+    for (wave_header = shared->wave_headers; wave_header; wave_header = next)
+    {
+        next = wave_header->next;
+        if (shared->wave)
+            waveOutUnprepareHeader(shared->wave, &wave_header->header, sizeof(wave_header->header));
+        if (wave_header->stream_status)
+            *wave_header->stream_status = 0;
+        free(wave_header->header.lpData);
+        free(wave_header);
+    }
+
+    if (shared->wave)
+        waveOutClose(shared->wave);
+
+    if (shared->stream_source)
+        IUnknown_Release(shared->stream_source);
+    free(shared->wave_format);
+    free(shared->stream_format);
+}
+
+static ULONG rsx_shared_release(struct rsx_shared *shared)
+{
+    ULONG ref = InterlockedDecrement(&shared->ref);
+
+    if (!ref)
+    {
+        if (rsx_global_shared == shared)
+            rsx_global_shared = NULL;
+        rsx_cleanup_wave_output(shared);
+        free(shared);
+    }
+
+    return ref;
+}
+
+static struct rsx_shared *rsx_shared_acquire(void)
+{
+    struct rsx_shared *shared = rsx_global_shared;
+
+    if (shared)
+    {
+        InterlockedIncrement(&shared->ref);
+        return shared;
+    }
+
+    if (!(shared = calloc(1, sizeof(*shared))))
+        return NULL;
+
+    shared->ref = 1;
+    rsx_global_shared = shared;
+    return shared;
+}
+
+static HRESULT WINAPI rsx_QueryInterface(IUnknown *iface, REFIID iid, void **out)
+{
+    struct rsx_object *object = impl_from_IUnknown(iface);
+
+    TRACE("iface %p, iid %s, out %p.\n", iface, debugstr_guid(iid), out);
+
+    if (!out) return E_POINTER;
+
+    if (IsEqualGUID(iid, &IID_IUnknown) || IsEqualGUID(iid, &IID_IRSX20)
+            || IsEqualGUID(iid, &IID_IRSXDirectListener)
+            || IsEqualGUID(iid, &IID_IRSXStreamingListener)
+            || IsEqualGUID(iid, &IID_IRSXDirectSound))
+    {
+        *out = &object->lpVtbl;
+        IUnknown_AddRef(iface);
+        return S_OK;
+    }
+
+    /* Overseer probes these RSX interfaces before falling back to standard audio. */
+    *out = NULL;
+    FIXME("RSX interface %s is not implemented.\n", debugstr_guid(iid));
+    return E_NOINTERFACE;
+}
+
+static ULONG WINAPI rsx_AddRef(IUnknown *iface)
+{
+    struct rsx_object *object = impl_from_IUnknown(iface);
+    return InterlockedIncrement(&object->ref);
+}
+
+static ULONG WINAPI rsx_Release(IUnknown *iface)
+{
+    struct rsx_object *object = impl_from_IUnknown(iface);
+    ULONG ref = InterlockedDecrement(&object->ref);
+
+    if (!ref)
+    {
+        rsx_shared_release(object->shared);
+        free(object);
+    }
+    return ref;
+}
+
