+static HRESULT WINAPI rsx_create_child(IUnknown *iface, void *desc, IUnknown **out, void *arg3)
+{
+    static LONG trace_count;
+
+    TRACE("iface %p, desc %p, out %p, arg3 %p, stub.\n", iface, desc, out, arg3);
+
+    if (!out) return E_POINTER;
+
+    rsx_cleanup_done_wave_headers(impl_from_IUnknown(iface)->shared);
+
+    if (desc && trace_count < 8 && !IsBadReadPtr(desc, 12))
+    {
+        const DWORD *state = desc;
+
+        InterlockedIncrement(&trace_count);
+        TRACE("create child desc %#lx %#lx %#lx.\n", state[0], state[1], state[2]);
+    }
+
+    *out = iface;
+    IUnknown_AddRef(iface);
+    return S_OK;
