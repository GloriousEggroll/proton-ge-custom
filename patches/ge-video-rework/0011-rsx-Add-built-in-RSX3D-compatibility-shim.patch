+HRESULT WINAPI DllRegisterServer(void)
+{
+    static const char threading_model[] = "Both";
+    static const char module[] = "rsx.dll";
+    char key_name[128];
+    unsigned int i;
+    HKEY class_key;
+    HKEY server_key;
+    LONG ret;
+
+    for (i = 0; i < ARRAY_SIZE(rsx_classes); ++i)
+    {
+        snprintf(key_name, sizeof(key_name), "CLSID\\%s", rsx_classes[i].guid);
+        if ((ret = RegCreateKeyA(HKEY_CLASSES_ROOT, key_name, &class_key)))
+            return HRESULT_FROM_WIN32(ret);
+
+        ret = RegSetValueExA(class_key, NULL, 0, REG_SZ,
+                (const BYTE *)rsx_classes[i].name, strlen(rsx_classes[i].name) + 1);
+        if (!ret && !(ret = RegCreateKeyA(class_key, "InprocServer32", &server_key)))
+        {
+            ret = RegSetValueExA(server_key, NULL, 0, REG_SZ, (const BYTE *)module, sizeof(module));
+            if (!ret)
+                ret = RegSetValueExA(server_key, "ThreadingModel", 0, REG_SZ,
+                        (const BYTE *)threading_model, sizeof(threading_model));
+            RegCloseKey(server_key);
+        }
+        RegCloseKey(class_key);
+
+        if (ret) return HRESULT_FROM_WIN32(ret);
+    }
+
+    set_rsx_wave_device();
+    return S_OK;
+}
+
+HRESULT WINAPI DllUnregisterServer(void)
+{
+    char key_name[128];
+    unsigned int i;
+
+    for (i = 0; i < ARRAY_SIZE(rsx_classes); ++i)
+    {
+        snprintf(key_name, sizeof(key_name), "CLSID\\%s", rsx_classes[i].guid);
+        RegDeleteTreeA(HKEY_CLASSES_ROOT, key_name);
+    }
+
+    return S_OK;
+}
