+    LONG ref;
+    HWAVEOUT wave;
+    WAVEFORMATEX *wave_format;
+    struct rsx_wave_header *wave_headers;
+    BYTE *stream_base;
+    HANDLE stream_thread;
+    HANDLE stream_stop;
+    WAVEFORMATEX *stream_format;
+    DWORD stream_stride;
+    DWORD stream_total_size;
+    IUnknown *stream_source;
+    BYTE *stream_ring_entry[32];
+    DWORD stream_ring_checksum[32];
+    DWORD stream_ring_count;
+    DWORD stream_ring_next;
