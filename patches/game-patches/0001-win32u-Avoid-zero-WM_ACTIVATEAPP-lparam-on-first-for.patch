From a5a33cc006d7ab0cac89539c53300666ca03ba91 Mon Sep 17 00:00:00 2001
From: GloriousEggroll <gloriouseggroll@gmail.com>
Date: Thu, 14 May 2026 14:46:03 -0600
Subject: [PATCH]  win32u: Avoid zero WM_ACTIVATEAPP lparam on first foreground
 activation.

  based on original patch from NelloKudo <marshnelloosu@gmail.com>:
  'HACK: win32u: Substitute non-zero WM_ACTIVATEAPP lparam for
 Guilty Gear XX Accent Core Plus R.'

  Some applications check the lparam of WM_ACTIVATEAPP(TRUE) to verify that
  they are gaining focus from another foreground thread. On Windows, there is
  typically a previous foreground window, so the value is non-zero.

  Under Proton, when the first Wine top-level foreground window activates,
  there may be no previous Wine active window/thread to report, causing
  WM_ACTIVATEAPP(TRUE) to be sent with lparam zero. Applications can interpret
  that as an inactive/no-focus transition.

  Use a small helper in set_active_window() to synthesize a non-zero thread id
  only for that first foreground activation case. Normal activations with a
  known previous thread continue to report the real old thread id.

  If you want to preserve the concrete game motivation, add a final line:

  This fixes Guilty Gear XX Accent Core Plus R skipping its intro movie.
---
 dlls/win32u/input.c | 25 ++++++++++++++++++++++++-
 1 file changed, 24 insertions(+), 1 deletion(-)

diff --git a/dlls/win32u/input.c b/dlls/win32u/input.c
index 868a457d764..bd101d0ff4a 100644
--- a/dlls/win32u/input.c
+++ b/dlls/win32u/input.c
@@ -2007,6 +2007,27 @@ static HWND set_focus_window( HWND hwnd, BOOL from_active, BOOL force )
     return previous;
 }
 
+static DWORD get_activateapp_thread_id( HWND hwnd, HWND previous, DWORD old_thread, DWORD new_thread )
+{
+    if (old_thread || !new_thread || previous)
+        return old_thread;
+
+    if (hwnd != NtUserGetForegroundWindow())
+        return old_thread;
+
+    if (NtUserGetAncestor( hwnd, GA_PARENT ) != get_desktop_window())
+        return old_thread;
+
+    /*
+     * When Wine activates its first foreground top-level window, there may be
+     * no previous Wine active window even though the host desktop did have a
+     * foreground application. Windows normally reports the old foreground
+     * thread here; use a non-zero placeholder so applications do not mistake
+     * the activation for an inactive/no-focus transition.
+     */
+    return new_thread;
+}
+
 /*******************************************************************
  *		set_active_window
  */
@@ -2081,10 +2102,12 @@ BOOL set_active_window( HWND hwnd, HWND *prev, BOOL mouse, BOOL focus, DWORD new
             }
             if (new_thread)
             {
+                DWORD activate_thread = get_activateapp_thread_id( hwnd, previous, old_thread, new_thread );
+
                 for (phwnd = list; *phwnd; phwnd++)
                 {
                     if (get_window_thread( *phwnd, NULL ) == new_thread)
-                        send_message( *phwnd, WM_ACTIVATEAPP, 1, old_thread );
+                        send_message( *phwnd, WM_ACTIVATEAPP, 1, activate_thread );
                 }
             }
             free( list );
