From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: GE-Proton <git@localhost>
Date: Fri, 10 Jul 2026 02:35:00 -0600
Subject: [PATCH] winepulse: Retarget DualSense mono after committing hotplug.

The PulseAudio refresh helper queues added and removed endpoints in temporary
delta lists. Retargeting Spider-Man Remastered's already-open DualSense mono
effect stream from that helper is too early during controller model switches:
the new controller speaker sink has not yet been committed to the active
speaker list, so the retarget helper can still see the stale removed sink or
miss the first newly-connected model.

Once pulse_get_endpoint_ids() has published the delta to mmdevapi and moved
added render devices into the active list, retarget live DualSense mono
streams. This lets a first DS -> DS Edge or DS Edge -> DS switch see the newly
committed controller speaker sink before the game triggers the next mono effect.
---
 dlls/winepulse.drv/pulse.c | 13 +++++++++++++
 1 file changed, 13 insertions(+)

diff --git a/dlls/winepulse.drv/pulse.c b/dlls/winepulse.drv/pulse.c
index 99999999999..aaaaaaaaaaa 100644
--- a/dlls/winepulse.drv/pulse.c
+++ b/dlls/winepulse.drv/pulse.c
@@ -582,6 +582,7 @@ static void pulse_wait_devices(struct list *list)
 
 static BOOL pulse_refresh_devices(EDataFlow flow);
 static void pulse_retarget_dualsense_mono_streams(void);
+static BOOL is_dualsense_speaker_sink(const PhysDevice *dev);
 
 /* for winepulse, this function can be called in a separate thread from other functions. */
 /* this function cannot be called from multiple threads at the same time however. */
@@ -599,6 +600,7 @@ static NTSTATUS pulse_get_endpoint_ids(void *args)
     BOOL refreshed;
     PhysDevice *dev, *dev_next;
     BOOL delta = params->delta;
+    BOOL retarget_dualsense_mono = FALSE;
 
     TRACE("flow %d, delta %d\n", (int)params->flow, (int)params->delta);
 
@@ -723,6 +725,8 @@ static NTSTATUS pulse_get_endpoint_ids(void *args)
         pulse_get_endpoints(list_removed, &endpoint, &offset, params->endpoints);
 
         LIST_FOR_EACH_ENTRY_SAFE(dev, dev_next, list_added, PhysDevice, entry) {
+            if (params->flow == eRender && is_dualsense_speaker_sink(dev))
+                retarget_dualsense_mono = TRUE;
             list_remove(&dev->entry);
             list_add_tail(list, &dev->entry);
         }
@@ -754,12 +758,21 @@ static NTSTATUS pulse_get_endpoint_ids(void *args)
         pulse_get_endpoints(list_added, &endpoint, &offset, params->endpoints);
 
         LIST_FOR_EACH_ENTRY_SAFE(dev, dev_next, list_added, PhysDevice, entry) {
+            if (params->flow == eRender && is_dualsense_speaker_sink(dev))
+                retarget_dualsense_mono = TRUE;
             list_remove(&dev->entry);
             list_add_tail(list, &dev->entry);
         }
     }
 
 done:
     g_phys_unlock();
+
+    if (retarget_dualsense_mono)
+    {
+        pulse_lock();
+        pulse_retarget_dualsense_mono_streams();
+        pulse_unlock();
+    }
 
     if (needed > params->size) {
         params->size = needed;
-- 
