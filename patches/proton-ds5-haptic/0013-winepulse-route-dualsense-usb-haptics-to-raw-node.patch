+static int16_t float_to_s16(float sample)
+{
+    if (sample > 1.0f) sample = 1.0f;
+    else if (sample < -1.0f) sample = -1.0f;
+
+    return sample < 0.0f ? sample * 32768.0f : sample * 32767.0f;
