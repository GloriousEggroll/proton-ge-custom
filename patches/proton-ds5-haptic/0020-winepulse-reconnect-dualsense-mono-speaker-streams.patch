+static HRESULT pulse_dualsense_mono_reconnect_internal(struct pulse_stream *stream, BOOL force)
+{
+    const char *current_device = NULL;
+    unsigned int generation;
+    pa_usec_t now;
+    char *device = NULL;
+    HRESULT hr;
+
+    if (!pulse_stream_dualsense_mono(stream))
+        return AUDCLNT_E_DEVICE_INVALIDATED;
+
+    g_phys_lock();
+    generation = g_haptic_hotplug_generation;
+    g_phys_unlock();
+
+    now = pa_rtclock_now();
+    if (stream->stream && !PA_STREAM_IS_GOOD(pa_stream_get_state(stream->stream)))
+        pulse_stream_disconnect(stream);
+
+    if (stream->haptic_reconnect_time && now < stream->haptic_reconnect_time)
+    {
+        free(device);
+        return AUDCLNT_E_DEVICE_INVALIDATED;
+    }
+
+    device = get_dualsense_speaker_sink(stream->device);
+    if (!device)
+    {
+        TRACE("DualSense mono speaker sink is not currently available, generation %u -> %u.\n",
+                stream->haptic_hotplug_generation, generation);
+        stream->haptic_hotplug_generation = generation;
+        stream->haptic_reconnect_time = now + DUALSENSE_HAPTIC_REFRESH_USEC;
+        return AUDCLNT_E_DEVICE_INVALIDATED;
+    }
+
+    if (pulse_stream_ready(stream))
+        current_device = pa_stream_get_device_name(stream->stream);
+    if (!force && current_device && !strcmp(current_device, device) && !strcmp(stream->device, device)
+            && stream->haptic_hotplug_generation == generation)
+    {
+        stream->haptic_reconnect_time = 0;
+        free(device);
+        return S_OK;
+    }
+    if (!force && current_device && !strcmp(current_device, device) && !strcmp(stream->device, device)
+            && !stream->haptic_reconnect_time)
+    {
+        TRACE("Deferring DualSense mono speaker reconnect for reused sink %s, generation %u -> %u.\n",
+                debugstr_a(device), stream->haptic_hotplug_generation, generation);
+        stream->haptic_reconnect_time = now + DUALSENSE_HAPTIC_REFRESH_USEC;
+        free(device);
+        return AUDCLNT_E_DEVICE_INVALIDATED;
+    }
+
+    TRACE("Reconnecting DualSense mono speaker stream from %s/%s to %s, generation %u -> %u.\n",
+            debugstr_a(stream->device), debugstr_a(current_device), debugstr_a(device),
+            stream->haptic_hotplug_generation, generation);
+
+    stream->haptic_hotplug_generation = generation;
+    stream->haptic_reconnect_time = now + DUALSENSE_HAPTIC_REFRESH_USEC;
+    pulse_stream_disconnect(stream);
+    hr = pulse_stream_connect(stream, device, NULL, stream->period_bytes);
+    if (SUCCEEDED(hr) && pulse_stream_ready(stream))
+    {
+        int success = 1;
+
+        if (strcmp(stream->device, device))
+        {
+            if (stream->started)
+            {
+                remove_stream_from_period(stream);
+                stream->period = NULL;
+            }
+            free(stream->device);
+            stream->device = device;
+            device = NULL;
+            if (stream->started)
+                pulse_add_stream_to_period(stream);
+        }
+        stream->haptic_hotplug_generation = generation;
+        stream->haptic_reconnect_time = 0;
+
+        if (stream->started && pulse_stream_ready(stream) && pa_stream_is_corked(stream->stream))
+        {
+            if (!wait_pa_operation_complete(pa_stream_cork(stream->stream, 0, pulse_op_cb, &success)))
+                success = 0;
+            if (!success)
+                hr = E_FAIL;
+        }
+    }
+    else
+    {
+        pulse_stream_disconnect(stream);
+        if (SUCCEEDED(hr))
+            hr = AUDCLNT_E_DEVICE_INVALIDATED;
+        stream->haptic_hotplug_generation = generation;
+        stream->haptic_reconnect_time = pa_rtclock_now() + DUALSENSE_HAPTIC_REFRESH_USEC;
+    }
+
+    free(device);
+    return hr;
+}
+
+static HRESULT pulse_dualsense_mono_reconnect(struct pulse_stream *stream)
+{
+    return pulse_dualsense_mono_reconnect_internal(stream, FALSE);
+}
+
+static void pulse_reconnect_dualsense_mono_streams(struct pulse_period *current_period)
+{
+    struct pulse_stream *stream, *next;
+    unsigned int generation;
+
+    if (list_empty(&dualsense_mono_streams))
+        return;
+
+    g_phys_lock();
+    generation = g_haptic_hotplug_generation;
+    g_phys_unlock();
+
+    LIST_FOR_EACH_ENTRY_SAFE(stream, next, &dualsense_mono_streams, struct pulse_stream, dualsense_mono_entry)
+    {
+        if (!stream->started)
+            continue;
+        if (stream->period == current_period && stream->haptic_hotplug_generation == generation
+                && pulse_stream_ready(stream))
+            continue;
+
+        if (stream->haptic_hotplug_generation != generation || !pulse_stream_ready(stream))
+            pulse_dualsense_mono_reconnect(stream);
+    }
+}
