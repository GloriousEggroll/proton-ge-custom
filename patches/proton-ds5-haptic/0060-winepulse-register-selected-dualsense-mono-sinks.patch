From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: GE-Proton <git@localhost>
Date: Thu, 9 Jul 2026 14:20:00 -0600
Subject: [PATCH] winepulse: Register selected DualSense mono speaker sinks.

Spider-Man Remastered may keep writing through an already-created controller
speaker IAudioClient after a controller swap instead of activating the newly
announced mono endpoint. The winepulse retarget path handles this, but stream
registration was based on the original Windows endpoint name containing a
DualSense-like string. After the mmdevapi hotplug cleanup, the reliable
identifier is the Pulse sink we actually selected for playback.

If a one-channel render stream resolves to a current DualSense speaker sink,
mark it as a DualSense mono stream even when the original MMDevice name was not
recognised. This lets the existing retarget-on-speaker-add path move the live
stream to the new DS or DS Edge speaker instead of relying on the game to open
another endpoint.
---
 dlls/winepulse.drv/pulse.c | 37 +++++++++++++++++++++++++++++++++++++
 1 file changed, 37 insertions(+)

diff --git a/dlls/winepulse.drv/pulse.c b/dlls/winepulse.drv/pulse.c
index 11111111111..22222222222 100644
--- a/dlls/winepulse.drv/pulse.c
+++ b/dlls/winepulse.drv/pulse.c
@@ -1207,6 +1207,34 @@ static BOOL is_dualsense_speaker_sink(const PhysDevice *dev)
             && strstr(dev->pulse_name, "Speaker__sink");
 }
 
+static BOOL pulse_name_looks_like_dualsense_speaker_sink(const char *name)
+{
+    return name && strstr(name, "alsa_output.usb-Sony_Interactive_Entertainment_")
+            && strstr(name, "Wireless_Controller") && strstr(name, "Speaker__sink");
+}
+
+static BOOL pulse_name_is_dualsense_speaker_sink(const char *name)
+{
+    PhysDevice *dev;
+    BOOL ret = FALSE;
+
+    if (!name)
+        return FALSE;
+
+    g_phys_lock();
+    LIST_FOR_EACH_ENTRY(dev, &g_phys_speakers, PhysDevice, entry)
+    {
+        if (!pulse_device_matches(dev, name))
+            continue;
+
+        ret = is_dualsense_speaker_sink(dev);
+        break;
+    }
+    g_phys_unlock();
+
+    return ret || pulse_name_looks_like_dualsense_speaker_sink(name);
+}
+
 static BOOL is_dualsense_haptic_format(const struct pulse_stream *stream)
 {
     return stream->dataflow == eRender && stream->ss.format == PA_SAMPLE_FLOAT32LE
@@ -2883,6 +2911,15 @@ static NTSTATUS pulse_create_stream(void *args)
         connect_device = dualsense_speaker;
     else if ((resolved_device = pulse_resolve_device_name(connect_device)))
         connect_device = resolved_device;
+
+    if (!dualsense_mono_candidate && !haptic_candidate && pulse_stream_dualsense_mono_format(stream)
+            && pulse_name_is_dualsense_speaker_sink(connect_device))
+    {
+        TRACE("Tracking DualSense mono stream for selected speaker sink %s.\n",
+                debugstr_a(connect_device));
+        dualsense_mono_candidate = TRUE;
+    }
+
     if (haptic_candidate)
     {
         stream->haptic_alsa_path = strdup(haptic_alsa_path ? haptic_alsa_path : "");
-- 
