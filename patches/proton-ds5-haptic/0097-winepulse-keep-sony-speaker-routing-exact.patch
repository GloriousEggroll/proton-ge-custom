From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: GE-Proton <git@localhost>
Date: Tue, 21 Jul 2026 17:55:00 -0600
Subject: [PATCH] winepulse: Keep Sony controller speaker routing exact.

The controller speaker hotplug path tracks the latest Sony speaker sink so
Spider-Man Remastered can keep its controller-effect stream alive across
physical controller swaps.  Do not let that preferred sink lookup silently
fall back to another Sony controller speaker when the requested sink is not
currently present.  During DS/DSE/DSH swaps, Pulse can briefly expose old and
new controller devices close together, and a cross-model fallback can leave
the game writing to a stream that is no longer the current controller speaker.

Also remember the concrete sink that a newly-created Sony controller speaker
stream actually connected to.  That keeps the preferred sink synchronized with
successful stream creation, not only with refresh callbacks.

---
 dlls/winepulse.drv/pulse.c | 23 +++++++++++++++++++----
 1 file changed, 19 insertions(+), 4 deletions(-)

diff --git a/dlls/winepulse.drv/pulse.c b/dlls/winepulse.drv/pulse.c
--- a/dlls/winepulse.drv/pulse.c
+++ b/dlls/winepulse.drv/pulse.c
@@ -2464,6 +2464,12 @@ static char *get_dualsense_speaker_sink(const char *preferred, BOOL require_spea
         }
     }
     g_phys_unlock();
+    if (preferred)
+    {
+        free(fallback);
+        free(direct_fallback);
+        return NULL;
+    }
     if (fallback)
     {
         free(direct_fallback);
@@ -3052,10 +3058,17 @@ static NTSTATUS pulse_create_stream(void *args)
     stream->share = params->share;
     stream->flags = params->flags;
     connect_device = params->device;
-    if (dualsense_mono_candidate && (dualsense_speaker = get_dualsense_speaker_sink(
-            g_dualsense_mono_preferred_sink ? g_dualsense_mono_preferred_sink : params->device, TRUE)))
-        connect_device = dualsense_speaker;
-    else if ((resolved_device = pulse_resolve_device_name(connect_device)))
+    if (dualsense_mono_candidate)
+    {
+        const char *preferred = g_dualsense_mono_preferred_sink ? g_dualsense_mono_preferred_sink : params->device;
+
+        dualsense_speaker = get_dualsense_speaker_sink(preferred, TRUE);
+        if (!dualsense_speaker && preferred != params->device && strcmp(preferred, params->device))
+            dualsense_speaker = get_dualsense_speaker_sink(params->device, TRUE);
+        if (dualsense_speaker)
+            connect_device = dualsense_speaker;
+    }
+    else if ((resolved_device = pulse_resolve_device_name(connect_device)))
         connect_device = resolved_device;
 
     if (!dualsense_mono_candidate && !haptic_candidate && pulse_name_is_dualsense_speaker_sink(connect_device))
@@ -3145,6 +3151,8 @@ static NTSTATUS pulse_create_stream(void *args)
             stream->haptic_hotplug_generation = g_haptic_hotplug_generation;
         if (dualsense_mono_candidate)
         {
+            pulse_set_dualsense_mono_preferred_sink(connect_device);
+
             stream->dualsense_mono_hotplug_generation = g_dualsense_mono_speaker_add_generation;
             list_add_tail(&dualsense_mono_streams, &stream->dualsense_mono_entry);
             stream->dualsense_mono_registered = TRUE;
