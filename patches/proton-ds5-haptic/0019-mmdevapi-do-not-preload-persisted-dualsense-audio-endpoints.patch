From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: GE-Proton <ge-proton@localhost>
Date: Sat, 4 Jul 2026 00:00:00 -0600
Subject: [PATCH 19/19] mmdevapi: Do not preload persisted DualSense endpoints.

DualSense USB audio endpoints are hotplug-sensitive. Preloading old persisted
DualSense render/capture endpoints as not-present devices can leave games bound
to stale endpoint ids after a disconnect/reconnect, while the live endpoint is
created separately.

Skip persisted DualSense endpoint names during mmdevapi startup and let the
driver refresh path publish the current live controller endpoints instead.
This keeps USB haptics and the controller mono speaker from being routed to a
stale endpoint after controller hotplug or controller swaps.
---
 dlls/mmdevapi/devenum.c | 12 ++++++++++--
 1 file changed, 10 insertions(+), 2 deletions(-)

diff --git a/dlls/mmdevapi/devenum.c b/dlls/mmdevapi/devenum.c
--- a/dlls/mmdevapi/devenum.c
+++ b/dlls/mmdevapi/devenum.c
@@ -95,6 +95,11 @@ static HRESULT set_format(MMDevice *dev);
 
 static const WCHAR devid_formatW[] = L"{0.0.%u.00000000}.{%08x-%04x-%04x-%02x%02x-%02x%02x%02x%02x%02x%02x}";
 
+static BOOL is_dualsense_endpoint_name( const WCHAR *name )
+{
+    return name && (wcsstr( name, L"DualSense" ) || wcsstr( name, L"Wireless Controller" ));
+}
+
 typedef struct MMDevColImpl
 {
     IMMDeviceCollection IMMDeviceCollection_iface;
@@ -1121,7 +1126,10 @@ HRESULT load_devices_from_reg(void)
             && pv.vt == VT_LPWSTR)
         {
-            MMDevice_Create(pv.pwszVal, &guid, curflow,
-                    DEVICE_STATE_NOTPRESENT, FALSE);
+            if (is_dualsense_endpoint_name( pv.pwszVal ))
+                TRACE("Skipping persisted DualSense endpoint %s.\n", debugstr_w(pv.pwszVal));
+            else
+                MMDevice_Create(pv.pwszVal, &guid, curflow,
+                        DEVICE_STATE_NOTPRESENT, FALSE);
             CoTaskMemFree(pv.pwszVal);
         }
     } while (1);
