From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: GE-Proton <git@localhost>
Date: Wed, 8 Jul 2026 13:20:00 -0600
Subject: [PATCH] mmdevapi: Hide DualSense mono endpoint after activation.

Spider-Man Remastered needs the DualSense mono speaker endpoint to be visible
long enough to discover and open it for controller speaker effects. After a
USB unplug/replug, the game successfully opens the current controller speaker
endpoint and effect audio plays, but a later broad endpoint enumeration sees
that same special one-channel endpoint again and the managed audio layer
crashes with InvalidCastException.

Keep new DualSense and DualSense Edge mono speaker endpoints visible until
their IAudioClient is successfully activated. After that, hide the endpoint
from broad EnumAudioEndpoints() collections while keeping explicit references,
GetDevice() by id, and already-created audio clients alive. A later controller
connect re-exposes the speaker endpoint and resets this visibility state, so
DS <-> DS Edge swaps can still bind to the newly connected physical device.
---
 dlls/mmdevapi/devenum.c          | 11 +++++++++--
 dlls/mmdevapi/mmdevapi_private.h |  1 +
 2 files changed, 10 insertions(+), 2 deletions(-)

diff --git a/dlls/mmdevapi/devenum.c b/dlls/mmdevapi/devenum.c
index d6b6ee33333..88b80ec4444 100644
--- a/dlls/mmdevapi/devenum.c
+++ b/dlls/mmdevapi/devenum.c
@@ -720,7 +720,8 @@ static BOOL is_dualsense_mono_endpoint(const MMDevice *device)
 
 static BOOL should_hide_from_endpoint_collection(const MMDevice *device)
 {
-    return is_dualsense_mono_endpoint(device) && !(device->state & DEVICE_STATE_ACTIVE);
+    return is_dualsense_mono_endpoint(device) &&
+            (!(device->state & DEVICE_STATE_ACTIVE) || device->hide_from_collection);
 }
 
 static BOOL should_prioritize_dualsense_mono_endpoint(const MMDevice *device)
@@ -1092,6 +1093,7 @@ static MMDevice *MMDevice_Create(const WCHAR *name, GUID *id, EDataFlow flow, DW
     device_iname = cur->drv_id;
     swprintf(friendly_name, FRIENDLY_NAME_MAX, friendly_name_fmt, device_desc, device_iname);
     cur->removed = FALSE;
+    cur->hide_from_collection = FALSE;
 
     cur->flow = flow;
     cur->state = state;
@@ -1597,5 +1599,11 @@ static HRESULT WINAPI MMDevice_Activate(IMMDevice *iface, REFIID riid, DWORD cls
     {
         hr = AudioClient_Create(&This->devguid, iface, (IAudioClient**)ppv);
+        if (SUCCEEDED(hr) && is_dualsense_mono_endpoint(This))
+        {
+            TRACE("Hiding activated DualSense mono endpoint %s from endpoint collections.\n",
+                    debugstr_guid(&This->devguid));
+            This->hide_from_collection = TRUE;
+        }
     }else if (IsEqualIID(riid, &IID_IAudioEndpointVolume) ||
             IsEqualIID(riid, &IID_IAudioEndpointVolumeEx))
         hr = AudioEndpointVolume_Create(This, (IAudioEndpointVolumeEx**)ppv);
diff --git a/dlls/mmdevapi/mmdevapi_private.h b/dlls/mmdevapi/mmdevapi_private.h
index 480424b41d6..ecfe3d1b6dd 100644
--- a/dlls/mmdevapi/mmdevapi_private.h
+++ b/dlls/mmdevapi/mmdevapi_private.h
@@ -111,6 +111,7 @@ typedef struct MMDevice {
     GUID devguid;
     WCHAR *drv_id;
     BOOL removed;
+    BOOL hide_from_collection;
 
     struct list entry;
 } MMDevice;
