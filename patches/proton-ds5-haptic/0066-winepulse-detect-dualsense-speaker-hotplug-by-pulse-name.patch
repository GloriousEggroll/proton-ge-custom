From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: GE-Proton <git@localhost>
Date: Thu, 9 Jul 2026 17:05:00 -0600
Subject: [PATCH] winepulse: Detect DualSense speaker hotplug by Pulse name.

Pulse does not always preserve complete USB vendor/product metadata for the
standard DualSense mono speaker sink during hotplug. After switching from a
DualSense Edge to a standard DualSense, the new speaker appeared as:

  alsa_output.usb-Sony_Interactive_Entertainment_Wireless_Controller-00.Default__Speaker__sink

but the mono retarget path did not treat it as a DualSense speaker add, so the
existing Spider-Man Remastered mono stream stayed tied to the removed Edge
speaker sink.

Keep raw haptics detection restricted to the existing device metadata, but let
the mono speaker routing path recognise Sony `Wireless_Controller`
`Speaker__sink` names as DualSense speaker endpoints. Apply the same test to
speaker removal so the mono generation is invalidated before the next controller
model is attached.
---
 dlls/winepulse.drv/pulse.c | 18 +++++++++++++-----
 1 file changed, 13 insertions(+), 5 deletions(-)

diff --git a/dlls/winepulse.drv/pulse.c b/dlls/winepulse.drv/pulse.c
index 77777777777..88888888888 100644
--- a/dlls/winepulse.drv/pulse.c
+++ b/dlls/winepulse.drv/pulse.c
@@ -1204,8 +1204,10 @@ static BOOL is_dualsense_audio_device(const PhysDevice *dev)
 
 static BOOL is_dualsense_speaker_sink(const PhysDevice *dev)
 {
-    return dev->flow == eRender && is_dualsense_audio_device(dev)
-            && strstr(dev->pulse_name, "Speaker__sink");
+    return dev->flow == eRender && strstr(dev->pulse_name, "Speaker__sink")
+            && (is_dualsense_audio_device(dev)
+                || (strstr(dev->pulse_name, "alsa_output.usb-Sony_Interactive_Entertainment_")
+                    && strstr(dev->pulse_name, "Wireless_Controller")));
 }
 
 static BOOL is_dualsense_endpoint_speaker_sink(const PhysDevice *dev)
@@ -1664,8 +1666,12 @@ static BOOL pulse_refresh_devices(EDataFlow flow)
         if (pulse_find_device(&current, dev->pulse_name))
             continue;
         TRACE("PulseAudio endpoint %s was removed.\n", debugstr_a(dev->pulse_name));
-        if (flow == eRender && is_dualsense_audio_device(dev))
+        if (flow == eRender && (is_dualsense_audio_device(dev) || is_dualsense_speaker_sink(dev)))
+        {
             ++g_haptic_hotplug_generation;
+            if (is_dualsense_speaker_sink(dev))
+                ++g_dualsense_mono_speaker_add_generation;
+        }
         list_remove(&dev->entry);
         list_add_tail(removed, &dev->entry);
     }
@@ -1678,7 +1684,7 @@ static BOOL pulse_refresh_devices(EDataFlow flow)
         }
 
         TRACE("PulseAudio endpoint %s was added.\n", debugstr_a(dev->pulse_name));
-        if (flow == eRender && is_dualsense_audio_device(dev))
+        if (flow == eRender && (is_dualsense_audio_device(dev) || is_dualsense_speaker_sink(dev)))
         {
             ++g_haptic_hotplug_generation;
             if (is_dualsense_speaker_sink(dev))
@@ -2352,10 +2358,10 @@ static char *get_dualsense_speaker_sink(const char *preferred, BOOL require_spea
         {
             BOOL direct, speaker;
 
-            if (!is_dualsense_audio_device(dev))
+            speaker = is_dualsense_speaker_sink(dev);
+            if (!speaker && !is_dualsense_audio_device(dev))
                 continue;
 
-            speaker = is_dualsense_speaker_sink(dev);
             direct = strstr(dev->pulse_name, "Direct__Direct__sink") || (dev->raw_haptic_target && !speaker);
             if (require_speaker && !speaker)
                 continue;
