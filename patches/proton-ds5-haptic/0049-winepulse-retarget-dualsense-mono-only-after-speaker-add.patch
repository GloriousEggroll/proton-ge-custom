From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: GE-Proton <git@localhost>
Date: Thu, 9 Jul 2026 02:05:00 -0600
Subject: [PATCH] winepulse: Retarget DualSense mono only after speaker add.

The shared DualSense haptic generation changes for both removal and addition
events. Using it for controller speaker retargeting makes unplugging a
controller attempt a synchronous mono stream reconnect from inside the active
Pulse period callback, often while the old sink is being removed. Pulse can
abort when that callback later restarts its timer.

Track a narrower generation for DualSense mono speaker sink additions only.
Live mono streams now retarget when a new controller speaker endpoint has
actually been added, while removal events only invalidate the endpoint list.
This keeps unplug safe and still lets Spider-Man retarget controller effect
audio after reconnecting the same controller or swapping between DualSense and
DualSense Edge.
---
 dlls/winepulse.drv/pulse.c | 18 +++++++++++++++++-
 1 file changed, 17 insertions(+), 1 deletion(-)

diff --git a/dlls/winepulse.drv/pulse.c b/dlls/winepulse.drv/pulse.c
--- a/dlls/winepulse.drv/pulse.c
+++ b/dlls/winepulse.drv/pulse.c
@@ -180,6 +180,7 @@
 static pthread_cond_t g_phys_cond = PTHREAD_COND_INITIALIZER;
 static unsigned int g_haptic_hotplug_generation;
 static unsigned int g_dualsense_endpoint_generation;
+static unsigned int g_dualsense_mono_speaker_add_generation;
 static unsigned int g_phys_event_mask;
 static unsigned int g_phys_event_stale_render;
 static unsigned int g_phys_event_stale_capture;
@@ -1173,6 +1174,12 @@
             && (dev->product_id == 0x0ce6 || dev->product_id == 0x0df2);
 }
 
+static BOOL is_dualsense_speaker_sink(const PhysDevice *dev)
+{
+    return dev->flow == eRender && is_dualsense_audio_device(dev) && !dev->raw_haptic_target
+            && strstr(dev->pulse_name, "Speaker__sink");
+}
+
 static BOOL is_dualsense_haptic_format(const struct pulse_stream *stream)
 {
     return stream->dataflow == eRender && stream->ss.format == PA_SAMPLE_FLOAT32LE
@@ -1601,7 +1608,11 @@
 
         TRACE("PulseAudio endpoint %s was added.\n", debugstr_a(dev->pulse_name));
         if (flow == eRender && is_dualsense_audio_device(dev))
+        {
             ++g_haptic_hotplug_generation;
+            if (is_dualsense_speaker_sink(dev))
+                ++g_dualsense_mono_speaker_add_generation;
+        }
         list_remove(&dev->entry);
         list_add_tail(added, &dev->entry);
     }
@@ -2341,6 +2352,7 @@
     if (SUCCEEDED(hr))
     {
         stream->haptic_hotplug_generation = g_haptic_hotplug_generation;
+        stream->dualsense_mono_hotplug_generation = g_dualsense_mono_speaker_add_generation;
         if (!stream->period)
             pulse_add_stream_to_period(stream);
         if (stream->started && pulse_stream_ready(stream) && pa_stream_is_corked(stream->stream))
@@ -2890,6 +2902,7 @@
             stream->haptic_hotplug_generation = g_haptic_hotplug_generation;
         if (dualsense_mono_candidate)
         {
+            stream->dualsense_mono_hotplug_generation = g_dualsense_mono_speaker_add_generation;
             list_add_tail(&dualsense_mono_streams, &stream->dualsense_mono_entry);
             stream->dualsense_mono_registered = TRUE;
         }
@@ -3113,7 +3126,8 @@
         return;
     }
 
-    if (stream->dualsense_mono_registered && stream->haptic_hotplug_generation != g_haptic_hotplug_generation
+    if (stream->dualsense_mono_registered
+            && stream->dualsense_mono_hotplug_generation != g_dualsense_mono_speaker_add_generation
             && FAILED(pulse_retarget_dualsense_mono_stream(stream)))
         return;
 
