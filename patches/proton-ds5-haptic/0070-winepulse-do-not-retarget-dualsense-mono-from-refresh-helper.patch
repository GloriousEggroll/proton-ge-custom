From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: GE-Proton <git@localhost>
Date: Fri, 10 Jul 2026 02:45:00 -0600
Subject: [PATCH] winepulse: Do not retarget DualSense mono from refresh helper.

pulse_refresh_devices() only builds the added/removed endpoint delta lists. At
that point newly-added controller speaker sinks have not been moved into the
active speaker list yet, so retargeting live DualSense mono streams from here
can keep the stream on the removed controller sink during DS <-> DS Edge model
switches.

Leave retargeting to pulse_get_endpoint_ids(), after it has committed added
render devices into the active list.
---
 dlls/winepulse.drv/pulse.c | 14 +-------------
 1 file changed, 1 insertion(+), 13 deletions(-)

diff --git a/dlls/winepulse.drv/pulse.c b/dlls/winepulse.drv/pulse.c
index 99999999999..aaaaaaaaaaa 100644
--- a/dlls/winepulse.drv/pulse.c
+++ b/dlls/winepulse.drv/pulse.c
@@ -1622,7 +1622,6 @@ static BOOL pulse_refresh_devices(EDataFlow flow)
     struct list *active = flow == eRender ? &g_phys_speakers : &g_phys_sources;
     struct list *added = flow == eRender ? &g_phys_speakers_added : &g_phys_sources_added;
     struct list *removed = flow == eRender ? &g_phys_speakers_removed : &g_phys_sources_removed;
-    BOOL dualsense_speaker_added = FALSE;
     PhysDevice *dev, *next;
     pa_mainloop *ml;
     pa_context *ctx;
@@ -1698,10 +1697,7 @@ static BOOL pulse_refresh_devices(EDataFlow flow)
         {
             ++g_haptic_hotplug_generation;
             if (is_dualsense_speaker_sink(dev))
-            {
                 ++g_dualsense_mono_speaker_add_generation;
-                dualsense_speaker_added = TRUE;
-            }
         }
         list_remove(&dev->entry);
         list_add_tail(added, &dev->entry);
@@ -1714,13 +1710,6 @@ static BOOL pulse_refresh_devices(EDataFlow flow)
     LIST_FOR_EACH_ENTRY_SAFE(dev, next, &current, PhysDevice, entry)
         pulse_dev_free(dev);
 
-    if (dualsense_speaker_added)
-    {
-        pulse_lock();
-        pulse_retarget_dualsense_mono_streams();
-        pulse_unlock();
-    }
-
     pthread_cond_broadcast(&g_phys_cond);
     return TRUE;
 
