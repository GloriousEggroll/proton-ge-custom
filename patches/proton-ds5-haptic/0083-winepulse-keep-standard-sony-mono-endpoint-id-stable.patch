From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: GE-Proton <git@localhost>
Date: Sat, 11 Jul 2026 09:15:00 -0600
Subject: [PATCH] winepulse: Keep standard Sony mono endpoint id stable.

Spider-Man Remastered probes the controller speaker at startup and later opens
the same logical endpoint for controller effect audio. The standard DualSense
speaker sink can carry raw haptic target metadata on PipeWire, but treating that
metadata as a reason to give the speaker a generated hotplug endpoint id makes
the game see a different controller-speaker identity and skip effect playback.

Keep standard DualSense and compatible DualShock speaker sinks on the shared
stable mono endpoint id even when raw haptic metadata is present. DualSense Edge
still keeps its separate model-specific endpoint id because exposing Edge through
the standard DualSense id crashes Spider-Man during endpoint enumeration.
---
 dlls/winepulse.drv/pulse.c | 17 +++++++++--------
 1 file changed, 9 insertions(+), 8 deletions(-)

diff --git a/dlls/winepulse.drv/pulse.c b/dlls/winepulse.drv/pulse.c
index 77777777777..88888888888 100644
--- a/dlls/winepulse.drv/pulse.c
+++ b/dlls/winepulse.drv/pulse.c
@@ -1251,22 +1251,23 @@ static BOOL is_dualsense_speaker_sink(const PhysDevice *dev)
                     && strstr(dev->pulse_name, "Wireless_Controller"))));
 }
 
-static BOOL is_dualsense_endpoint_speaker_sink(const PhysDevice *dev)
-{
-    /* Edge speaker sinks may also carry raw haptic metadata. They are valid
-     * routing targets, but using the standard DualSense mono endpoint id for
-     * them makes Spider-Man Remastered crash while enumerating endpoints at
-     * startup. */
-    return is_dualsense_speaker_sink(dev) && !dev->raw_haptic_target;
-}
-
 static BOOL is_dualsense_edge_speaker_sink(const PhysDevice *dev)
 {
     return is_dualsense_speaker_sink(dev) &&
             (dev->product_id == 0x0df2 ||
              strstr(dev->pulse_name, "DualSense_Edge_Wireless_Controller"));
 }
 
+static BOOL is_dualsense_endpoint_speaker_sink(const PhysDevice *dev)
+{
+    /* Keep the standard DualSense/DualShock controller speaker on the shared
+     * app-facing endpoint id even if Pulse also tagged it as a raw haptic
+     * target. DualSense Edge keeps a separate id below; sharing the standard
+     * id with Edge makes Spider-Man Remastered crash while enumerating
+     * endpoints at startup. */
+    return is_dualsense_speaker_sink(dev) && !is_dualsense_edge_speaker_sink(dev);
+}
+
 static BOOL pulse_name_looks_like_dualsense_speaker_sink(const char *name)
 {
     return name && strstr(name, "alsa_output.usb-Sony_Interactive_Entertainment_")
-- 
