From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: GE-Proton <git@localhost>
Date: Fri, 10 Jul 2026 04:45:00 -0600
Subject: [PATCH] winepulse: Prefer the newly-added DualSense speaker on
 retarget.

PulseAudio can briefly report the old controller speaker sink and the newly
attached replacement sink at the same time during a DualSense <-> DualSense
Edge swap. We retarget Spider-Man Remastered's already-open controller speaker
stream after committing the render hotplug batch, but the generic sink lookup
can still pick the stale old speaker if it remains in the active list for that
refresh.

Remember the exact DualSense speaker sink that was added in the render delta
and use it as the preferred retarget. The generic fallback remains in place for
normal writes and for cases where the preferred sink disappears before the
stream can be rebound.
---
 dlls/winepulse.drv/pulse.c | 23 +++++++++++++++--------
 1 file changed, 15 insertions(+), 8 deletions(-)

diff --git a/dlls/winepulse.drv/pulse.c b/dlls/winepulse.drv/pulse.c
index 99999999999..aaaaaaaaaaa 100644
--- a/dlls/winepulse.drv/pulse.c
+++ b/dlls/winepulse.drv/pulse.c
@@ -582,7 +582,7 @@ static void pulse_wait_devices(struct list *list)
 }
 
 static BOOL pulse_refresh_devices(EDataFlow flow);
-static void pulse_retarget_dualsense_mono_streams(void);
+static void pulse_retarget_dualsense_mono_streams(const char *preferred);
 static BOOL is_dualsense_speaker_sink(const PhysDevice *dev);
 
 /* for winepulse, this function can be called in a separate thread from other functions. */
@@ -607,6 +607,7 @@ static NTSTATUS pulse_get_endpoint_ids(void *args)
     PhysDevice *dev, *dev_next;
     BOOL delta = params->delta;
     BOOL retarget_dualsense_mono = FALSE;
+    char *dualsense_mono_target = NULL;
 
     TRACE("flow %d, delta %d\n", (int)params->flow, (int)params->delta);
 
@@ -730,7 +731,11 @@ static NTSTATUS pulse_get_endpoint_ids(void *args)
 
         LIST_FOR_EACH_ENTRY_SAFE(dev, dev_next, list_added, PhysDevice, entry) {
             if (params->flow == eRender && is_dualsense_speaker_sink(dev))
+            {
                 retarget_dualsense_mono = TRUE;
+                free(dualsense_mono_target);
+                dualsense_mono_target = strdup(dev->pulse_name);
+            }
             list_remove(&dev->entry);
             list_add_tail(list, &dev->entry);
         }
@@ -761,7 +766,11 @@ static NTSTATUS pulse_get_endpoint_ids(void *args)
 
         LIST_FOR_EACH_ENTRY_SAFE(dev, dev_next, list_added, PhysDevice, entry) {
             if (params->flow == eRender && is_dualsense_speaker_sink(dev))
+            {
                 retarget_dualsense_mono = TRUE;
+                free(dualsense_mono_target);
+                dualsense_mono_target = strdup(dev->pulse_name);
+            }
             list_remove(&dev->entry);
             list_add_tail(list, &dev->entry);
         }
@@ -773,9 +782,10 @@ done:
     if (retarget_dualsense_mono)
     {
         pulse_lock();
-        pulse_retarget_dualsense_mono_streams();
+        pulse_retarget_dualsense_mono_streams(dualsense_mono_target);
         pulse_unlock();
     }
+    free(dualsense_mono_target);
 
     if (needed > params->size) {
         params->size = needed;
@@ -2418,7 +2428,7 @@ static void pulse_stream_disconnect(struct pulse_stream *stream)
     stream->update_timing_info_pending = FALSE;
 }
 
-static HRESULT pulse_retarget_dualsense_mono_stream(struct pulse_stream *stream)
+static HRESULT pulse_retarget_dualsense_mono_stream(struct pulse_stream *stream, const char *preferred)
 {
     char *dualsense_speaker;
     int success;
@@ -2428,7 +2438,7 @@ static HRESULT pulse_retarget_dualsense_mono_stream(struct pulse_stream *stream)
             && !pulse_stream_dualsense_mono(stream))
         return S_FALSE;
 
-    if (!(dualsense_speaker = get_dualsense_speaker_sink(NULL, TRUE)))
+    if (!(dualsense_speaker = get_dualsense_speaker_sink(preferred, TRUE)))
         return E_FAIL;
 
     if (!strcmp(stream->device, dualsense_speaker))
@@ -2483,7 +2493,7 @@ static HRESULT pulse_retarget_dualsense_mono_stream(struct pulse_stream *stream)
     return hr;
 }
 
-static void pulse_retarget_dualsense_mono_streams(void)
+static void pulse_retarget_dualsense_mono_streams(const char *preferred)
 {
     struct pulse_stream *stream, *next;
 
@@ -2494,7 +2504,7 @@ static void pulse_retarget_dualsense_mono_streams(void)
                 && pulse_stream_ready(stream))
             continue;
 
-        pulse_retarget_dualsense_mono_stream(stream);
+        pulse_retarget_dualsense_mono_stream(stream, preferred);
     }
 }
 
@@ -3266,7 +3276,7 @@ static void pulse_write(struct pulse_stream *stream)
             && (stream->dualsense_mono_hotplug_generation != g_dualsense_mono_speaker_add_generation
                 || stream->haptic_hotplug_generation != g_haptic_hotplug_generation
                 || !pulse_stream_ready(stream))
-            && FAILED(pulse_retarget_dualsense_mono_stream(stream)))
+            && FAILED(pulse_retarget_dualsense_mono_stream(stream, NULL)))
         return;
 
     if (!pulse_stream_ready(stream))
-- 
2.54.0
