From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: GE-Proton <git@localhost>
Date: Mon, 6 Jul 2026 00:00:00 -0600
Subject: [PATCH 25/25] winepulse: Finish nonfatal pre-mainloop hotplug delta.

Complete the pre-mainloop audio hotplug worker fix by removing the remaining
fatal result path from the delta wait. The update thread must not die before
Pulse/PipeWire has delivered controller speaker add/remove events, otherwise
Spider-Man never receives a replacement DualSense mono speaker endpoint after
USB reconnect or controller swap.
---
 dlls/winepulse.drv/pulse.c | 14 +++++++-------
 1 file changed, 7 insertions(+), 7 deletions(-)

diff --git a/dlls/winepulse.drv/pulse.c b/dlls/winepulse.drv/pulse.c
--- a/dlls/winepulse.drv/pulse.c
+++ b/dlls/winepulse.drv/pulse.c
@@ -613,10 +613,10 @@ static NTSTATUS pulse_get_endpoint_ids(void *args)
 
     if (delta)
     {
-        params->more_data = FALSE;
         /* also check if we are still running */
-        if (!pulse_ml) {
-            unavailable = TRUE;
+        if (!pulse_ml)
+        {
+            g_phys_cond_timedwait_ms(1000);
             goto done;
         }
         if (!list_count(list_added) && !list_count(list_removed))
@@ -629,8 +629,9 @@ static NTSTATUS pulse_get_endpoint_ids(void *args)
             }
             while (!(g_phys_event_mask & event_mask))
             {
-                if (!pulse_ml) {
-                    unavailable = TRUE;
+                if (!pulse_ml)
+                {
+                    g_phys_cond_timedwait_ms(1000);
                     goto done;
                 }
                 if (g_phys_event_mask & ~event_mask)
@@ -724,8 +725,6 @@ done:
     if (needed > params->size) {
         params->size = needed;
         params->result = HRESULT_FROM_WIN32(ERROR_INSUFFICIENT_BUFFER);
-    } else if (unavailable) {
-        params->result = AUDCLNT_E_DEVICE_INVALIDATED;
     } else {
         params->delta = TRUE;
         params->result = S_OK;
-- 
