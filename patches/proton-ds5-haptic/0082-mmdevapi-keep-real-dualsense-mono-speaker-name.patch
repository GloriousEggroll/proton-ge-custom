From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: "GE-Proton" <git@localhost>
Date: Sat, 11 Jul 2026 07:31:00 -0600
Subject: [PATCH] mmdevapi: Keep the real DualSense mono speaker endpoint name.

Spider-Man Remastered selects the controller effects endpoint from the
render collection by its normal speaker identity.  Renaming the mono
speaker to the generic "Wireless Controller Speaker" leaves the endpoint
visible, but the game no longer activates it for controller effect audio.

Keep the Pulse-provided mono speaker name, e.g.
"DualSense Edge wireless controller (PS5) Internal Mono Speaker", and only
skip Sony product-name overrides for these mono endpoints.  The fake PnP
AudioEndpoint registration remains skipped separately, and stale fake
AudioEndpoint devices using either the old generic name or the real mono
speaker name are still removed, so this does not reintroduce the endpoint
enumeration crash.
---
 dlls/mmdevapi/devenum.c | 17 ++++-------------
 1 file changed, 4 insertions(+), 13 deletions(-)

diff --git a/dlls/mmdevapi/devenum.c b/dlls/mmdevapi/devenum.c
index 429043ec3d6..3b253c688e5 100644
--- a/dlls/mmdevapi/devenum.c
+++ b/dlls/mmdevapi/devenum.c
@@ -723,15 +723,6 @@ static BOOL is_dualsense_device_path(const WCHAR *device_path)
             wcsstr(device_path, L"VID_054C&PID_0DF2"));
 }
 
-static const WCHAR *dualsense_mono_endpoint_iname(const WCHAR *device_path)
-{
-    if (!device_path)
-        return NULL;
-    if (is_dualsense_device_path(device_path))
-        return L"Wireless Controller Speaker";
-    return NULL;
-}
-
 static BOOL is_dualsense_mono_endpoint_name(const WCHAR *name)
 {
     if (!name)
@@ -981,10 +972,11 @@ static void remove_dualsense_media_devices(void)
 
 static BOOL is_dualsense_audioendpoint_name(const WCHAR *name)
 {
-    return name && (wcsstr(name, L"Wireless Controller Speaker") ||
+    return is_dualsense_mono_endpoint_name(name) ||
+            (name && (wcsstr(name, L"Wireless Controller Speaker") ||
             wcsstr(name, L"DualShock 4 Wireless Controller Speaker") ||
             wcsstr(name, L"DualSense Wireless Controller Speaker") ||
-            wcsstr(name, L"DualSense Edge Wireless Controller Speaker"));
+            wcsstr(name, L"DualSense Edge Wireless Controller Speaker")));
 }
 
 static void remove_dualsense_audioendpoint_devices(void)
@@ -1323,10 +1314,7 @@ static MMDevice *MMDevice_Create(const WCHAR *name, GUID *id, EDataFlow flow, DW
             if (SUCCEEDED(set_driver_prop_value(id, flow, &devicepath_key))) {
                 if (SUCCEEDED(MMDevice_GetPropValue(id, flow, &devicepath_key, &device_path)) && device_path.vt == VT_LPWSTR) {
                     const WCHAR *override;
-                    if (dualsense_mono_endpoint && (override = dualsense_mono_endpoint_iname(device_path.pwszVal))) {
-                        device_iname = override;
-                        swprintf(friendly_name, FRIENDLY_NAME_MAX, friendly_name_fmt, device_desc, device_iname);
-                    } else if ((override = find_product_name_override(device_path.pwszVal)) != NULL) {
+                    if (!dualsense_mono_endpoint && (override = find_product_name_override(device_path.pwszVal)) != NULL) {
                         device_iname = override;
                         swprintf(friendly_name, FRIENDLY_NAME_MAX, friendly_name_fmt, device_desc, device_iname);
                     }
