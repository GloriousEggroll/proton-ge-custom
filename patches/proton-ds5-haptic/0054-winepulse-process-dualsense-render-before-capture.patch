From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: GE-Proton <git@localhost>
Date: Thu, 9 Jul 2026 07:10:00 -0600
Subject: [PATCH] winepulse: Add helper for pending DualSense audio endpoint
 deltas.

The DualSense mono speaker hotplug path needs to recognize pending controller
audio endpoint deltas before they are converted into mmdevapi endpoint
notifications. Add a small list helper for that check, shared by the follow-up
ordering fix.
---
 dlls/winepulse.drv/pulse.c | 14 ++++++++++++++
 1 file changed, 14 insertions(+)

diff --git a/dlls/winepulse.drv/pulse.c b/dlls/winepulse.drv/pulse.c
index 11111111111..22222222222 100644
--- a/dlls/winepulse.drv/pulse.c
+++ b/dlls/winepulse.drv/pulse.c
@@ -203,6 +203,20 @@ static BYTE *silence_buf;
 #define PHYS_EVENT_RENDER 0x1
 #define PHYS_EVENT_CAPTURE 0x2
 
+static BOOL device_list_has_dualsense_audio_device(struct list *devices)
+{
+    PhysDevice *dev;
+
+    LIST_FOR_EACH_ENTRY(dev, devices, PhysDevice, entry)
+    {
+        if (dev->bus_type == phys_device_bus_usb && dev->vendor_id == 0x054c
+                && (dev->product_id == 0x0ce6 || dev->product_id == 0x0df2))
+            return TRUE;
+    }
+
+    return FALSE;
+}
+
 static NTSTATUS pulse_not_implemented(void *args)
 {
     return STATUS_SUCCESS;
-- 
2.54.0
