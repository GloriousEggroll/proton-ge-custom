From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: GE-Proton <git@localhost>
Date: Mon, 13 Jul 2026 14:10:00 -0600
Subject: [PATCH] mmdevapi: Prefer visible Sony mono endpoints before default.

Spider-Man Remastered can refresh the render collection after a Sony
controller hotplug and only inspect item 0.  The current collection order
always returns the normal default render endpoint first, so the game can
miss the fresh controller speaker endpoint until another unplug/replug.

While a Sony controller speaker endpoint is visible, keep it at the front
of the collection.  Activated controller endpoints are still hidden after
IAudioClient activation, and disconnected endpoints are still removed by
the existing forget path, so this does not preserve stale controller
state.

---
 dlls/mmdevapi/devenum.c | 17 +++++++++--------
 1 file changed, 9 insertions(+), 8 deletions(-)

diff --git a/dlls/mmdevapi/devenum.c b/dlls/mmdevapi/devenum.c
index 5f9bb874bb7..6829618afa3 100644
--- a/dlls/mmdevapi/devenum.c
+++ b/dlls/mmdevapi/devenum.c
@@ -2235,29 +2235,30 @@ static HRESULT MMDevCol_Create(IMMDeviceCollection **ppv, EDataFlow flow, DWORD
             return E_OUTOFMEMORY;
         }
 
-        if (default_device && collection_device_visible(default_device, flow, state))
-        {
-            This->devices[i] = &default_device->IMMDevice_iface;
-            IMMDevice_AddRef(This->devices[i]);
-            i++;
-        }
-
         LIST_FOR_EACH_ENTRY(cur, &device_list, MMDevice, entry)
         {
-            if (cur == default_device || !collection_device_visible(cur, flow, state) ||
+            if (!collection_device_visible(cur, flow, state) ||
                     !should_prioritize_dualsense_mono_endpoint(cur))
                 continue;
             This->devices[i] = &cur->IMMDevice_iface;
             IMMDevice_AddRef(This->devices[i]);
             i++;
         }
 
+        if (default_device && collection_device_visible(default_device, flow, state) &&
+                !should_prioritize_dualsense_mono_endpoint(default_device))
+        {
+            This->devices[i] = &default_device->IMMDevice_iface;
+            IMMDevice_AddRef(This->devices[i]);
+            i++;
+        }
+
         LIST_FOR_EACH_ENTRY(cur, &device_list, MMDevice, entry)
         {
             if (cur == default_device || !collection_device_visible(cur, flow, state) ||
                     should_prioritize_dualsense_mono_endpoint(cur))
                 continue;
             This->devices[i] = &cur->IMMDevice_iface;
             IMMDevice_AddRef(This->devices[i]);
             i++;
         }
