From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: GE-Proton <git@localhost>
Date: Thu, 9 Jul 2026 16:45:00 -0600
Subject: [PATCH] winepulse: Keep raw DualSense speaker endpoint ids
 model-specific.

DualSense Edge exposes its controller speaker sink with raw haptic target
metadata. We still need to treat that sink as a valid physical mono routing
target so existing mono streams can be retargeted across controller swaps, but
it must not reuse the generic standard DualSense app-facing endpoint id.

Spider-Man Remastered crashes at the main menu when a DualSense Edge starts
under that shared mono endpoint identity. Split the routing classification from
the endpoint-id classification so raw speaker sinks can still be routed to
without being exposed as the stable logical mono endpoint.
---
 dlls/winepulse.drv/pulse.c | 10 +++++++++-
 1 file changed, 9 insertions(+), 1 deletion(-)

diff --git a/dlls/winepulse.drv/pulse.c b/dlls/winepulse.drv/pulse.c
index 66666666666..77777777777 100644
--- a/dlls/winepulse.drv/pulse.c
+++ b/dlls/winepulse.drv/pulse.c
@@ -1204,6 +1204,14 @@ static BOOL is_dualsense_speaker_sink(const PhysDevice *dev)
             && strstr(dev->pulse_name, "Speaker__sink");
 }
 
+static BOOL is_dualsense_endpoint_speaker_sink(const PhysDevice *dev)
+{
+    /* Edge speaker sinks may also carry raw haptic metadata. They are valid
+     * routing targets, but using the shared mono endpoint id for them makes
+     * Spider-Man Remastered crash while enumerating endpoints at startup. */
+    return is_dualsense_speaker_sink(dev) && !dev->raw_haptic_target;
+}
+
 static BOOL pulse_name_looks_like_dualsense_speaker_sink(const char *name)
 {
     return name && strstr(name, "alsa_output.usb-Sony_Interactive_Entertainment_")
@@ -1260,7 +1269,7 @@ static BOOL pulse_set_endpoint_id(PhysDevice *dev)
     unsigned int generation;
     size_t len;
 
-    if (is_dualsense_speaker_sink(dev))
+    if (is_dualsense_endpoint_speaker_sink(dev))
         return !!(dev->endpoint_id = strdup(DUALSENSE_MONO_ENDPOINT_ID));
 
     if (!is_dualsense_audio_device(dev) || (dev->flow == eRender && !dev->raw_haptic_target
-- 
