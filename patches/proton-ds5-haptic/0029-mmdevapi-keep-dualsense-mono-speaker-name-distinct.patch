From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: GE-Proton <git@localhost>
Date: Mon, 6 Jul 2026 00:00:00 -0600
Subject: [PATCH] mmdevapi: Keep DualSense mono speaker name distinct.

Spider-Man Remastered opens the DualSense mono speaker endpoint for controller
effect audio, but its managed audio enumeration can crash if that extra render
endpoint is reported with the same interface name as the controller product
itself.

Keep the product-specific DualSense naming needed by the haptics/audio-device
path, but qualify the mono speaker endpoint as a speaker. This keeps it visible
as a controller speaker while avoiding a second render endpoint that looks like
the normal DualSense controller endpoint.
---
 dlls/mmdevapi/devenum.c | 20 +++++++++++++-------
 1 file changed, 13 insertions(+), 7 deletions(-)

diff --git a/dlls/mmdevapi/devenum.c b/dlls/mmdevapi/devenum.c
index 6186b01a103..dc36ab2ab89 100644
--- a/dlls/mmdevapi/devenum.c
+++ b/dlls/mmdevapi/devenum.c
@@ -699,9 +699,15 @@ static BOOL is_dualsense_device_path(const WCHAR *device_path)
             wcsstr(device_path, L"VID_054C&PID_0DF2"));
 }
 
-static BOOL is_dualsense_standard_device_path(const WCHAR *device_path)
+static const WCHAR *dualsense_mono_endpoint_iname(const WCHAR *device_path)
 {
-    return device_path && wcsstr(device_path, L"VID_054C&PID_0CE6");
+    if (!device_path)
+        return NULL;
+    if (wcsstr(device_path, L"VID_054C&PID_0CE6"))
+        return L"DualSense Wireless Controller Speaker";
+    if (wcsstr(device_path, L"VID_054C&PID_0DF2"))
+        return L"DualSense Edge Wireless Controller Speaker";
+    return NULL;
 }
 
 static BOOL is_dualsense_mono_endpoint_name(const WCHAR *name)
@@ -1034,13 +1040,13 @@ static MMDevice *MMDevice_Create(const WCHAR *name, GUID *id, EDataFlow flow, DW
             if (SUCCEEDED(set_driver_prop_value(id, flow, &devicepath_key))) {
                 if (SUCCEEDED(MMDevice_GetPropValue(id, flow, &devicepath_key, &device_path)) && device_path.vt == VT_LPWSTR) {
                     const WCHAR *override;
-                    if ((override = find_product_name_override(device_path.pwszVal)) != NULL) {
+                    if (dualsense_mono_endpoint && (override = dualsense_mono_endpoint_iname(device_path.pwszVal))) {
+                        device_iname = override;
+                        swprintf(friendly_name, FRIENDLY_NAME_MAX, friendly_name_fmt, device_desc, device_iname);
+                    } else if ((override = find_product_name_override(device_path.pwszVal)) != NULL) {
                         device_iname = override;
                         swprintf(friendly_name, FRIENDLY_NAME_MAX, friendly_name_fmt, device_desc, device_iname);
                     }
-                    if (dualsense_mono_endpoint && is_dualsense_standard_device_path(device_path.pwszVal))
-                        swprintf(friendly_name, FRIENDLY_NAME_MAX, friendly_name_fmt,
-                                device_desc, L"DualSense Wireless Controller");
                 }
             }
 
