From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: GE-Proton <git@localhost>
Date: Fri, 10 Jul 2026 11:15:00 -0600
Subject: [PATCH] mmdevapi: Retire old hidden DualSense mono endpoints.

Spider-Man Remastered may activate a newly-added DualSense / DualSense Edge
mono speaker endpoint after controller swaps. We hide those activated endpoints
from normal endpoint collections so they remain app-facing logical controller
speaker endpoints, while winepulse retargets their streams to the current
physical controller speaker sink.

After multiple DS <-> DS Edge swaps, the hidden logical endpoints can pile up.
The game then sees several old logical mono endpoints along with the new
physical endpoint, and can stop activating the new controller speaker on a
later swap. Keep only the currently activated hidden DualSense mono endpoint in
the device list. Older hidden mono endpoints are marked removed and detached
from enumeration, but are only freed immediately if there are no outstanding
references.
---
 dlls/mmdevapi/devenum.c | 23 +++++++++++++++++++++++
 1 file changed, 23 insertions(+)

--- a/dlls/mmdevapi/devenum.c
+++ b/dlls/mmdevapi/devenum.c
@@ -1848,6 +1848,28 @@
     return ref;
 }
 
+static void retire_old_hidden_dualsense_mono_endpoints(MMDevice *active)
+{
+    MMDevice *device, *next;
+
+    EnterCriticalSection(&device_list_cs);
+    LIST_FOR_EACH_ENTRY_SAFE(device, next, &device_list, MMDevice, entry)
+    {
+        if (device == active || !is_dualsense_mono_endpoint(device) || !device->hide_from_collection)
+            continue;
+
+        TRACE("Retiring old hidden DualSense mono endpoint %s after activating %s.\n",
+                debugstr_guid(&device->devguid), debugstr_guid(&active->devguid));
+        device->removed = TRUE;
+        device->state = DEVICE_STATE_NOTPRESENT;
+        list_remove(&device->entry);
+        list_init(&device->entry);
+        if (!device->ref)
+            MMDevice_Destroy(device);
+    }
+    LeaveCriticalSection(&device_list_cs);
+}
+
 static HRESULT WINAPI MMDevice_Activate(IMMDevice *iface, REFIID riid, DWORD clsctx, PROPVARIANT *params, void **ppv)
 {
     HRESULT hr = E_NOINTERFACE;
@@ -1874,6 +1896,7 @@
             This->dualsense_mono_activation_serial = InterlockedIncrement(&dualsense_mono_activation_serial);
             remove_mmdevice_audioendpoint_device(&This->devguid, This->flow);
             delete_mmdevice_registry_key(&This->devguid, This->flow);
+            retire_old_hidden_dualsense_mono_endpoints(This);
         }
     }else if (IsEqualIID(riid, &IID_IAudioEndpointVolume) ||
             IsEqualIID(riid, &IID_IAudioEndpointVolumeEx))
-- 
