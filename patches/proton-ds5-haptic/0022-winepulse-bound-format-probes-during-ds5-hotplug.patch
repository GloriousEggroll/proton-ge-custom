From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: GE-Proton <git@localhost>
Date: Mon, 6 Jul 2026 00:00:00 -0600
Subject: [PATCH 22/22] winepulse: Bound format probes during DS5 hotplug.

The DS5 hotplug delta path refreshes PulseAudio/PipeWire endpoints with a
private mainloop. The endpoint list query itself is now bounded, but each
endpoint is also probed with a temporary stream to discover its mix format and
period. If the controller speaker disappears while this probe is creating or
disconnecting, the hotplug worker can still block inside pa_mainloop_iterate()
and never return to mmdevapi.

Use the same bounded wait helper for the temporary probe stream. If the stream
does not leave the expected state in time, abandon that probe and keep the
worker alive so a later render add event can publish the new DualSense mono
speaker endpoint to games such as Spider-Man.
---
 dlls/winepulse.drv/pulse.c | 11 +++++------
 1 file changed, 5 insertions(+), 6 deletions(-)

diff --git a/dlls/winepulse.drv/pulse.c b/dlls/winepulse.drv/pulse.c
--- a/dlls/winepulse.drv/pulse.c
+++ b/dlls/winepulse.drv/pulse.c
@@ -1518,19 +1518,17 @@ static void pulse_probe_settings(pa_mainloop *ml, pa_context *ctx, int render, c
     else
         ret = pa_stream_connect_record(stream, pulse_name, &attr, PA_STREAM_START_CORKED|PA_STREAM_FIX_RATE|PA_STREAM_FIX_CHANNELS|PA_STREAM_EARLY_REQUESTS);
     if (ret >= 0) {
-        while (pa_mainloop_iterate(ml, 1, &ret) >= 0 &&
-                pa_stream_get_state(stream) == PA_STREAM_CREATING)
-        {}
+        pulse_stream_wait_until_not(ml, stream, PA_STREAM_CREATING, "format probe stream");
         if (pa_stream_get_state(stream) == PA_STREAM_READY) {
             ss = *pa_stream_get_sample_spec(stream);
             map = *pa_stream_get_channel_map(stream);
             if (render)
                 length = pa_stream_get_buffer_attr(stream)->minreq;
             else
                 length = pa_stream_get_buffer_attr(stream)->fragsize;
             pa_stream_disconnect(stream);
-            while (pa_mainloop_iterate(ml, 1, &ret) >= 0 &&
-                    pa_stream_get_state(stream) == PA_STREAM_READY)
-            {}
+            pulse_stream_wait_until_not(ml, stream, PA_STREAM_READY, "format probe disconnect");
         }
+        else if (pa_stream_get_state(stream) == PA_STREAM_CREATING)
+            pa_stream_disconnect(stream);
     }
 
     if (stream)
