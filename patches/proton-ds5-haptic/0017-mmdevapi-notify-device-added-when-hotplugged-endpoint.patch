From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: GE-Proton <git@localhost>
Date: Mon, 29 Jun 2026 00:00:00 -0600
Subject: [PATCH 17/17] mmdevapi: Notify device added when a hotplugged
 endpoint becomes active again.

The DualSense USB haptic endpoint can keep the same mmdevapi GUID across
disconnect/reconnect. When that happens the update thread marks the existing
device NOTPRESENT on removal, then MMDevice_Create() only emits
OnDeviceStateChanged when the endpoint returns as ACTIVE.

Some games only recreate their haptic audio client from an add notification.
Treat NOTPRESENT -> ACTIVE as a re-add and send OnDeviceAdded before the state
notification, while preserving the existing behavior for new devices and other
state transitions.
---
 dlls/mmdevapi/devenum.c | 9 +++++++--
 1 file changed, 7 insertions(+), 2 deletions(-)

diff --git a/dlls/mmdevapi/devenum.c b/dlls/mmdevapi/devenum.c
index 11111111111..22222222222 100644
--- a/dlls/mmdevapi/devenum.c
+++ b/dlls/mmdevapi/devenum.c
@@ -874,6 +874,7 @@ static MMDevice *MMDevice_Create(const WCHAR *name, GUID *id, EDataFlow flow, DW
     WCHAR guidstr[39];
     PROPVARIANT device_path, container_id;
     BOOL update_add = FALSE;
+    BOOL update_readd = FALSE;
     BOOL update_state = FALSE;
     WCHAR friendly_name[FRIENDLY_NAME_MAX];
     const WCHAR *device_iname;
@@ -905,8 +906,11 @@ static MMDevice *MMDevice_Create(const WCHAR *name, GUID *id, EDataFlow flow, DW
     } else {
         if (cur->ref > 0)
             WARN("Modifying an MMDevice with positive reference count!\n");
-        if (cur->state != state)
+        if (cur->state != state) {
+            if (cur->state == DEVICE_STATE_NOTPRESENT && state == DEVICE_STATE_ACTIVE)
+                update_readd = TRUE;
             update_state = TRUE;
+        }
     }
 
     free(cur->drv_id);
@@ -1033,7 +1037,7 @@ static MMDevice *MMDevice_Create(const WCHAR *name, GUID *id, EDataFlow flow, DW
     if (state == DEVICE_STATE_ACTIVE)
         set_format(cur);
 
-    if (update_add || update_state)
+    if (update_add || update_readd || update_state)
     {
         struct NotificationClientWrapper *wrapper;
         WCHAR devid[56];
@@ -1047,7 +1051,7 @@ static MMDevice *MMDevice_Create(const WCHAR *name, GUID *id, EDataFlow flow, DW
         EnterCriticalSection(&g_notif_lock);
         LIST_FOR_EACH_ENTRY(wrapper, &g_notif_clients, struct NotificationClientWrapper, entry)
         {
-            if (update_add)
+            if (update_add || update_readd)
                 IMMNotificationClient_OnDeviceAdded(wrapper->client, devid);
             if (update_add || update_state)
                 IMMNotificationClient_OnDeviceStateChanged(wrapper->client, devid, state);
