From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: GE-Proton <git@localhost>
Date: Fri, 10 Jul 2026 13:25:00 -0600
Subject: [PATCH] ds5-haptic: Add DualShock to the Sony controller speaker path.

The controller speaker/effect path has model-specific handling for standard
DualSense and DualSense Edge. DualShock 4 exposes the same Sony USB audio
family as `054c:05c4` / `054c:09cc`, but PipeWire commonly exposes its render
side as `DualShock 4 ... Analog Stereo` instead of the DualSense-style
`Internal Mono Speaker` / `Speaker__sink` pair.

Include DualShock 4 in the Sony controller audio checks and treat the DualShock
analog-stereo render endpoint as the controller speaker route for effect audio.
Expose it through the same app-facing logical endpoint/model as the standard
DualSense speaker while keeping the physical Pulse sink model-specific. Some
games cache and reopen the already-known "Wireless Controller" speaker endpoint
across controller swaps, and never activate a third, DualShock-specific logical
endpoint after it is signaled.
---
 dlls/mmdevapi/devenum.c    | 18 ++++++++++++------
 dlls/winepulse.drv/pulse.c | 25 ++++++++++++++++++++-----
 2 files changed, 32 insertions(+), 11 deletions(-)

--- a/dlls/mmdevapi/devenum.c
+++ b/dlls/mmdevapi/devenum.c
@@ -103,7 +103,8 @@ static const WCHAR devid_formatW[] = L"{0.0.%u.00000000}.{%08x-%04x-%04x-%02x%0
 
 static BOOL is_dualsense_endpoint_name( const WCHAR *name )
 {
-    return name && (wcsstr( name, L"DualSense" ) || wcsstr( name, L"Wireless Controller" ));
+    return name && (wcsstr( name, L"DualSense" ) || wcsstr( name, L"DualShock" ) ||
+            wcsstr( name, L"Wireless Controller" ));
 }
 
 static BOOL device_is_published(const GUID *devguid, EDataFlow flow)
@@ -688,5 +689,7 @@ static const struct product_name_overrides product_name_overrides[] =
 {
     /* Sony controllers */
+    { .id = L"VID_054C&PID_05C4", .product = L"DualShock 4 Wireless Controller" },
+    { .id = L"VID_054C&PID_09CC", .product = L"DualShock 4 Wireless Controller" },
     { .id = L"VID_054C&PID_0CE6", .product = L"DualSense Wireless Controller" },
     { .id = L"VID_054C&PID_0DF2", .product = L"DualSense Edge Wireless Controller" },
 };
@@ -715,5 +718,7 @@ static BOOL is_dualsense_device_path(const WCHAR *device_path)
 {
-    return device_path && (wcsstr(device_path, L"VID_054C&PID_0CE6") ||
+    return device_path && (wcsstr(device_path, L"VID_054C&PID_05C4") ||
+            wcsstr(device_path, L"VID_054C&PID_09CC") ||
+            wcsstr(device_path, L"VID_054C&PID_0CE6") ||
             wcsstr(device_path, L"VID_054C&PID_0DF2"));
 }
 
@@ -727,5 +732,13 @@ static const WCHAR *dualsense_mono_endpoint_iname(const WCHAR *device_path)
 
 static BOOL is_dualsense_mono_endpoint_name(const WCHAR *name)
 {
-    return name && wcsstr(name, L"DualSense") && wcsstr(name, L"Internal Mono Speaker");
+    if (!name)
+        return FALSE;
+
+    if (wcsstr(name, L"DualShock") && (wcsstr(name, L"Internal Mono Speaker") ||
+            wcsstr(name, L"Analog Stereo")))
+        return TRUE;
+
+    return (wcsstr(name, L"DualSense") || wcsstr(name, L"Wireless Controller")) &&
+            wcsstr(name, L"Internal Mono Speaker");
 }
@@ -953,5 +970,6 @@ static BOOL is_dualsense_audioendpoint_name(const WCHAR *name)
 {
     return name && (wcsstr(name, L"Wireless Controller Speaker") ||
+            wcsstr(name, L"DualShock 4 Wireless Controller Speaker") ||
             wcsstr(name, L"DualSense Wireless Controller Speaker") ||
             wcsstr(name, L"DualSense Edge Wireless Controller Speaker"));
 }
--- a/dlls/winepulse.drv/pulse.c
+++ b/dlls/winepulse.drv/pulse.c
@@ -213,7 +213,8 @@ static BOOL device_list_has_dualsense_audio_device(struct list *devices)
     LIST_FOR_EACH_ENTRY(dev, devices, PhysDevice, entry)
     {
         if (dev->bus_type == phys_device_bus_usb && dev->vendor_id == 0x054c
-                && (dev->product_id == 0x0ce6 || dev->product_id == 0x0df2))
+                && (dev->product_id == 0x05c4 || dev->product_id == 0x09cc ||
+                    dev->product_id == 0x0ce6 || dev->product_id == 0x0df2))
             return TRUE;
     }
 
@@ -1223,6 +1224,19 @@ static BOOL is_dualsense_audio_device(const PhysDevice *dev)
 {
     return dev->bus_type == phys_device_bus_usb && dev->vendor_id == 0x054c
-            && (dev->product_id == 0x0ce6 || dev->product_id == 0x0df2);
+            && (dev->product_id == 0x05c4 || dev->product_id == 0x09cc ||
+                dev->product_id == 0x0ce6 || dev->product_id == 0x0df2);
 }
+
+static BOOL is_dualshock_audio_device(const PhysDevice *dev)
+{
+    return dev->bus_type == phys_device_bus_usb && dev->vendor_id == 0x054c
+            && (dev->product_id == 0x05c4 || dev->product_id == 0x09cc);
+}
+
+static BOOL is_dualshock_speaker_sink(const PhysDevice *dev)
+{
+    return dev->flow == eRender && is_dualshock_audio_device(dev) &&
+            (strstr(dev->pulse_name, "Speaker__sink") || strstr(dev->pulse_name, "analog-stereo"));
+}
 
 static BOOL is_dualsense_speaker_sink(const PhysDevice *dev)
@@ -1231,8 +1245,9 @@ static BOOL is_dualsense_speaker_sink(const PhysDevice *dev)
 {
-    return dev->flow == eRender && strstr(dev->pulse_name, "Speaker__sink")
+    return is_dualshock_speaker_sink(dev) ||
+            (dev->flow == eRender && strstr(dev->pulse_name, "Speaker__sink")
             && (is_dualsense_audio_device(dev)
                 || (strstr(dev->pulse_name, "alsa_output.usb-Sony_Interactive_Entertainment_")
-                    && strstr(dev->pulse_name, "Wireless_Controller")));
+                    && strstr(dev->pulse_name, "Wireless_Controller"))));
 }
 
 static BOOL is_dualsense_endpoint_speaker_sink(const PhysDevice *dev)
@@ -1260,7 +1275,8 @@ static BOOL pulse_name_looks_like_dualsense_speaker_sink(const char *name)
 {
     return name && strstr(name, "alsa_output.usb-Sony_Interactive_Entertainment_")
-            && strstr(name, "Wireless_Controller") && strstr(name, "Speaker__sink");
+            && strstr(name, "Wireless_Controller") &&
+            (strstr(name, "Speaker__sink") || strstr(name, "analog-stereo"));
 }
 
 static BOOL pulse_name_is_dualsense_speaker_sink(const char *name)
 {
@@ -1307,6 +1321,9 @@ static BOOL pulse_set_endpoint_id(PhysDevice *dev)
     if (is_dualsense_edge_speaker_sink(dev))
         return !!(dev->endpoint_id = strdup(DUALSENSE_EDGE_MONO_ENDPOINT_ID));
 
+    if (is_dualshock_speaker_sink(dev))
+        return !!(dev->endpoint_id = strdup(DUALSENSE_MONO_ENDPOINT_ID));
+
     if (is_dualsense_endpoint_speaker_sink(dev))
         return !!(dev->endpoint_id = strdup(DUALSENSE_MONO_ENDPOINT_ID));
 
-- 
