-
     TRACE("max target luminance: %u\n", max);
 
     output->pending.max_target_lum = max;
     output->pending_flags |= WAYLAND_OUTPUT_CHANGED_MAX_TARGET_L;
-
-    pthread_mutex_unlock(&process_wayland.output_mutex);
