@@ -495,8 +448,6 @@ static void wayland_image_description_info_v1_target_primaries(void *data,
 {
     struct wayland_output *output = data;
 
-    pthread_mutex_lock(&process_wayland.output_mutex);
-
 #define COPY(name) output->pending.primaries.name = round((name * 1e-6) * 1024)
     COPY(r_x);
     COPY(r_y);
@@ -513,8 +464,6 @@ static void wayland_image_description_info_v1_target_primaries(void *data,
             b_x * 1e-6, b_y * 1e-6, w_x * 1e-6, w_y * 1e-6);
 
     output->pending_flags |= WAYLAND_OUTPUT_CHANGED_PRIMARIES;
-
-    pthread_mutex_unlock(&process_wayland.output_mutex);
 }
 
