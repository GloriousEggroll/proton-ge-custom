From 1c09848c0b512dcdb09966afb9ae93558309c42c Mon Sep 17 00:00:00 2001
From: Etaash Mathamsetty
 <45927311+Etaash-mathamsetty@users.noreply.github.com>
Date: Sun, 10 Aug 2025 21:53:04 -0400
Subject: [PATCH 236/506] ntdll: Add TRACE when setting up trampolines

---
 dlls/ntdll/loader.c      | 1 +
 dlls/ntdll/unix/loader.c | 2 ++
 2 files changed, 3 insertions(+)

diff --git a/dlls/ntdll/loader.c b/dlls/ntdll/loader.c
index 604b4f87c46..da0569f179a 100644
--- a/dlls/ntdll/loader.c
+++ b/dlls/ntdll/loader.c
@@ -2342,6 +2342,7 @@ static NTSTATUS build_module( LPCWSTR load_path, const UNICODE_STRING *nt_name,
         (lsteamclient || LdrLoadDll(load_path, 0, &lsteamclient_us, &lsteamclient) == STATUS_SUCCESS))
     {
         struct steamclient_setup_trampolines_params params = {.src_mod = *module, .tgt_mod = lsteamclient};
+        TRACE("setting up trampolines for %p (%s)\n", *module, debugstr_wn(basename, basename_len));
         WINE_UNIX_CALL( unix_steamclient_setup_trampolines, &params );
         NtFlushInstructionCache( NtCurrentProcess(), *module, map_size );
         if (is_steamclient32)
diff --git a/dlls/ntdll/unix/loader.c b/dlls/ntdll/unix/loader.c
index 7bb1f533d50..9c933ed763a 100644
--- a/dlls/ntdll/unix/loader.c
+++ b/dlls/ntdll/unix/loader.c
@@ -651,6 +651,8 @@ NTSTATUS exec_wineloader( char **argv, int socketfd, const struct pe_image_info
         strcpy( env, "LD_PRELOAD=" );
         strcat( env, ld_preload );
 
+        TRACE("HACK: Unsetting LD_PRELOAD for explorer.exe\n");
+
         tmp = env + 11;
         do
         {
