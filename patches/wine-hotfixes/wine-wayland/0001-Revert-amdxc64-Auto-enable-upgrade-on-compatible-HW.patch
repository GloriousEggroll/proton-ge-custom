Date: Wed, 24 Jun 2026 03:56:24 -0400
Subject: [PATCH 001/193] Revert "amdxc64: Auto-enable upgrade on compatible
 HW."

This reverts commit c257871b12dbe8d0196e76da494eaeda87e37c6f.
---
 dlls/amdxc64/Makefile.in |  2 +-
 dlls/amdxc64/main.c      | 71 +---------------------------------------
 2 files changed, 2 insertions(+), 71 deletions(-)

diff --git a/dlls/amdxc64/Makefile.in b/dlls/amdxc64/Makefile.in
index 4d9660ac960..a27f1da40ff 100644
--- a/dlls/amdxc64/Makefile.in
+++ b/dlls/amdxc64/Makefile.in
@@ -1,5 +1,5 @@
 MODULE = amdxc64.dll
-IMPORTS = version vulkan-1 user32 gdi32 dxgi
+IMPORTS = version vulkan-1 user32 gdi32
 IMPORTLIB = amdxc64
 
 EXTRADLLFLAGS = -mno-cygwin
diff --git a/dlls/amdxc64/main.c b/dlls/amdxc64/main.c
index 1d7f8e8de78..9c1e7977e54 100644
--- a/dlls/amdxc64/main.c
+++ b/dlls/amdxc64/main.c
@@ -31,7 +31,6 @@
 #define COBJMACROS
 #include "initguid.h"
 #include "d3d12.h"
-#include "dxgi1_4.h"
 
 #include "amdxc_interfaces.h"
 
@@ -41,7 +40,6 @@ struct AMDFSR4FFX
 {
     IAmdExtFfxApi IAmdExtFfxApi_iface;
     LONG ref;
-    LUID luid;
 };
 
 static struct AMDFSR4FFX* impl_from_IAmdExtFfxApi(IAmdExtFfxApi* iface)
@@ -70,56 +68,12 @@ HRESULT STDMETHODCALLTYPE AMDFSR4FFX_QueryInterface(IAmdExtFfxApi *iface, REFIID
     return E_NOINTERFACE;
 }
 
