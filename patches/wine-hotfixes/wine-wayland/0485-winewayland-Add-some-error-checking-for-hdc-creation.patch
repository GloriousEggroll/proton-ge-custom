From 21ff31ab0d209fb587039f506322db6a848137f4 Mon Sep 17 00:00:00 2001
From: Etaash Mathamsetty
 <45927311+Etaash-mathamsetty@users.noreply.github.com>
Date: Mon, 2 Mar 2026 20:57:59 -0600
Subject: [PATCH 485/502] winewayland: Add some error checking for hdc
 creation.

---
 dlls/winewayland.drv/wayland_pointer.c | 5 +++++
 dlls/winewayland.drv/wayland_surface.c | 6 +++++-
 2 files changed, 10 insertions(+), 1 deletion(-)

diff --git a/dlls/winewayland.drv/wayland_pointer.c b/dlls/winewayland.drv/wayland_pointer.c
index a3418dc74b5..2d4589450eb 100644
--- a/dlls/winewayland.drv/wayland_pointer.c
+++ b/dlls/winewayland.drv/wayland_pointer.c
@@ -774,6 +774,11 @@ static void wayland_pointer_update_cursor_buffer(HCURSOR hcursor, double scale)
     if (info.hbmColor)
     {
         HDC hdc = NtGdiCreateCompatibleDC(0);
+        if (!hdc)
+        {
+            ERR("Failed to create hdc.\n");
+            goto clear_cursor;
+        }
         cursor->shm_buffer =
             wayland_shm_buffer_from_color_bitmaps(hdc, info.hbmColor, info.hbmMask, FALSE);
         NtGdiDeleteObjectApp(hdc);
diff --git a/dlls/winewayland.drv/wayland_surface.c b/dlls/winewayland.drv/wayland_surface.c
index 709f6111ad2..85944aaa890 100644
--- a/dlls/winewayland.drv/wayland_surface.c
+++ b/dlls/winewayland.drv/wayland_surface.c
@@ -1407,7 +1407,11 @@ void wayland_surface_set_icon(struct wayland_surface *surface, UINT type, ICONIN
     assert(ii);
     assert(wayland_surface_is_toplevel(surface));
 
-    hDC = NtGdiCreateCompatibleDC(0);
+    if (!(hDC = NtGdiCreateCompatibleDC(0)))
+    {
+        ERR("Failed to create hDC.\n");
+        return;
+    }
     icon_buf = wayland_shm_buffer_from_color_bitmaps(hDC, ii->hbmColor, ii->hbmMask, TRUE);
     NtGdiDeleteObjectApp(hDC);
 
-- 
2.53.0

