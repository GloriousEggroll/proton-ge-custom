From 8aec4f48e416ea08ff7ce0b389a8e0f3a9c2ec4e Mon Sep 17 00:00:00 2001
From: Etaash Mathamsetty <etaash.mathamsetty@gmail.com>
Date: Fri, 12 Jun 2026 15:33:49 -0400
Subject: [PATCH 007/185] win32u: Always flush the window surface in
 expose_window_surface.

---
 dlls/win32u/window.c | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/dlls/win32u/window.c b/dlls/win32u/window.c
index 0fb8d74eaba..5a459a924a3 100644
--- a/dlls/win32u/window.c
+++ b/dlls/win32u/window.c
@@ -2438,7 +2438,7 @@ static BOOL expose_window_surface( HWND hwnd, UINT flags, const RECT *rect, UINT
         add_bounds_rect( &surface->bounds, &exposed_rect );
     }
     window_surface_unlock( surface );
-    if (surface->alpha_mask) window_surface_flush( surface );
+    window_surface_flush( surface );
     window_surface_release( surface );
     return TRUE;
 }
