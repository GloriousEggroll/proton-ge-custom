diff --git a/dlls/winewayland.drv/wayland_touch.c b/dlls/winewayland.drv/wayland_touch.c
new file mode 100644
index 00000000000..2e83accb239
--- /dev/null
+++ b/dlls/winewayland.drv/wayland_touch.c
@@ -0,0 +1,252 @@
+/*
+ * Wayland touch handling (for Proton)
+ *
+ * Copyright (c) 2026 Etaash Mathamsetty
+ *
+ * This library is free software; you can redistribute it and/or
+ * modify it under the terms of the GNU Lesser General Public
