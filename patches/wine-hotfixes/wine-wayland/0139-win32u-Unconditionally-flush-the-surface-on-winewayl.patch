From 11a244563ad35e92ee06386ce81a091cdb652161 Mon Sep 17 00:00:00 2001
From: Etaash Mathamsetty
 <45927311+Etaash-mathamsetty@users.noreply.github.com>
Date: Mon, 1 Jun 2026 03:19:25 -0400
Subject: [PATCH 139/153] win32u: Unconditionally flush the surface on
 winewayland.

This was the old behavior before this function was introduced, some drivers behave in slightly different ways and now standardizing it has caused issues for winewayland.
---
 dlls/win32u/window.c | 3 ++-
 1 file changed, 2 insertions(+), 1 deletion(-)

diff --git a/dlls/win32u/window.c b/dlls/win32u/window.c
index ba15fa32ee1..341fb4968f4 100644
--- a/dlls/win32u/window.c
+++ b/dlls/win32u/window.c
@@ -2504,7 +2504,8 @@ static BOOL expose_window_surface( HWND hwnd, UINT flags, const RECT *rect, UINT
         add_bounds_rect( &surface->bounds, &exposed_rect );
     }
     window_surface_unlock( surface );
-    if (surface->alpha_mask) window_surface_flush( surface );
+    if (surface->alpha_mask || !user_driver->dc_funcs.pPutImage)
+        window_surface_flush( surface );
     window_surface_release( surface );
     return TRUE;
 }
