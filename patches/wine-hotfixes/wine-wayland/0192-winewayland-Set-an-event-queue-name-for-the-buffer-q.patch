From 8e8fabaa24d548d2d4bb3ca48dd8aedf340ebcc5 Mon Sep 17 00:00:00 2001
From: Etaash Mathamsetty
 <45927311+Etaash-mathamsetty@users.noreply.github.com>
Date: Mon, 13 Jul 2026 00:18:34 -0400
Subject: [PATCH 192/193] winewayland: Set an event queue name for the buffer
 queue.

---
 dlls/winewayland.drv/window_surface.c | 4 ++++
 1 file changed, 4 insertions(+)

diff --git a/dlls/winewayland.drv/window_surface.c b/dlls/winewayland.drv/window_surface.c
index e7595b7ccb0..77548873f15 100644
--- a/dlls/winewayland.drv/window_surface.c
+++ b/dlls/winewayland.drv/window_surface.c
@@ -111,7 +111,11 @@ static struct wayland_buffer_queue *wayland_buffer_queue_create(int width, int h
     queue = calloc(1, sizeof(*queue));
     if (!queue) goto err;
 
+#if (WAYLAND_VERSION_MAJOR == 1 && WAYLAND_VERSION_MINOR >= 23)
+    queue->wl_event_queue = wl_display_create_queue_with_name(process_wayland.wl_display, "winewayland buffer queue");
+#else
     queue->wl_event_queue = wl_display_create_queue(process_wayland.wl_display);
+#endif
     if (!queue->wl_event_queue) goto err;
     queue->width = width;
     queue->height = height;
