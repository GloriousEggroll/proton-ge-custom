From 97acead4cd852a80e8860d0b35d69cd3fe112dc8 Mon Sep 17 00:00:00 2001
From: Etaash Mathamsetty
 <45927311+Etaash-mathamsetty@users.noreply.github.com>
Date: Tue, 2 Jun 2026 20:00:51 -0400
Subject: [PATCH 143/153] winewayland: Add missing traces for client surfaces.

---
 dlls/winewayland.drv/wayland_surface.c | 6 ++++++
 1 file changed, 6 insertions(+)

diff --git a/dlls/winewayland.drv/wayland_surface.c b/dlls/winewayland.drv/wayland_surface.c
index 255d4ff6cab..8e28593d4ed 100644
--- a/dlls/winewayland.drv/wayland_surface.c
+++ b/dlls/winewayland.drv/wayland_surface.c
@@ -1582,6 +1582,8 @@ static void wayland_client_surface_detach(struct client_surface *client)
     struct wayland_client_surface *surface = impl_from_client_surface(client);
     struct wayland_win_data *data;
 
+    TRACE("%s\n", debugstr_client_surface(client));
+
     if ((data = wayland_win_data_get(client->hwnd)))
     {
         if (data->client_surface == surface) data->client_surface = NULL;
@@ -1596,6 +1598,8 @@ static void wayland_client_surface_update(struct client_surface *client)
     HWND hwnd = client->hwnd, toplevel = NtUserGetAncestor(hwnd, GA_ROOT);
     struct wayland_win_data *data;
 
+    TRACE("%s\n", debugstr_client_surface(client));
+
     if (!(data = wayland_win_data_get(hwnd))) return;
 
     if (toplevel && NtUserIsWindowVisible(hwnd))
@@ -1721,6 +1725,8 @@ void wayland_client_surface_attach(struct wayland_client_surface *client, HWND t
         wl_subsurface_set_desync(client->wl_subsurface);
 
         client->toplevel = toplevel;
+
+        TRACE("Created subsurface for toplevel=%p\n", toplevel);
     }
 
     NtUserGetClientRect(hwnd, &client_rect, NtUserGetWinMonitorDpi(hwnd, MDT_RAW_DPI));
-- 
