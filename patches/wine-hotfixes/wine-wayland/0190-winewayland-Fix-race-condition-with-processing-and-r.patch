From: Etaash Mathamsetty
 <45927311+Etaash-mathamsetty@users.noreply.github.com>
Date: Sun, 12 Jul 2026 19:33:22 -0400
Subject: [PATCH 190/193] winewayland: Fix race condition with processing and
 requested config.

---
 dlls/winewayland.drv/wayland_surface.c | 3 +++
 1 file changed, 3 insertions(+)

diff --git a/dlls/winewayland.drv/wayland_surface.c b/dlls/winewayland.drv/wayland_surface.c
index 2d5d4cb5697..510db0855d5 100644
--- a/dlls/winewayland.drv/wayland_surface.c
+++ b/dlls/winewayland.drv/wayland_surface.c
@@ -970,6 +970,9 @@ static BOOL wayland_surface_reconfigure_xdg(struct wayland_surface *surface, REC
     {
         surface->current = surface->requested;
         memset(&surface->requested, 0, sizeof(surface->requested));
+        /* clear stale processing config if the requested one is newer */
+        if (surface->current.serial > surface->processing.serial)
+            memset(&surface->processing, 0, sizeof(surface->processing));
         xdg_surface_ack_configure(surface->xdg_surface, surface->current.serial);
     }
     else if (!surface->current.serial ||
