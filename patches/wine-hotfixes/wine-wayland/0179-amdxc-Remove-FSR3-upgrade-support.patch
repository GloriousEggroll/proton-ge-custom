From: Etaash Mathamsetty
 <45927311+Etaash-mathamsetty@users.noreply.github.com>
Date: Wed, 1 Jul 2026 15:54:38 -0400
Subject: [PATCH 179/193] amdxc: Remove FSR3 upgrade support

It doesn't work on valve DLL with RDNA3
---
 dlls/amdxc64/main.c | 7 -------
 1 file changed, 7 deletions(-)

diff --git a/dlls/amdxc64/main.c b/dlls/amdxc64/main.c
index bc22420a2b8..02eb7fd9d6f 100644
--- a/dlls/amdxc64/main.c
+++ b/dlls/amdxc64/main.c
@@ -462,7 +462,6 @@ HRESULT STDMETHODCALLTYPE AmdExtD3DDevice8_GetWaveMatrixProperties(IAmdExtD3DDev
             AMD_EXT_WMMA_TYPE_FP32, AMD_EXT_WMMA_TYPE_FP32, FALSE
         }
     };
-    const char *e;
 
     TRACE("%p %p %p\n", iface, pCount, pProperties);
 
@@ -474,12 +473,6 @@ HRESULT STDMETHODCALLTYPE AmdExtD3DDevice8_GetWaveMatrixProperties(IAmdExtD3DDev
         return S_OK;
     }
 
-    if ((e = getenv("FSR3_UPGRADE")) && !strcmp(e, "1"))
-    {
-        *pCount = 0;
-        return S_OK;
-    }
-
     if (*pCount >= sizeof(prop)/sizeof(prop[0]))
     {
         *pCount = sizeof(prop)/sizeof(prop[0]);
-- 
