From 1676b62229cf32a71d5ea9a97026766671fd6629 Mon Sep 17 00:00:00 2001
From: Etaash Mathamsetty
 <45927311+Etaash-mathamsetty@users.noreply.github.com>
Date: Fri, 19 Jun 2026 17:50:42 -0400
Subject: [PATCH 151/193] win32u: Add WINE_ENABLE_HARDWARE_SCHEDULING option.

---
 dlls/win32u/d3dkmt.c | 8 ++++++++
 1 file changed, 8 insertions(+)

diff --git a/dlls/win32u/d3dkmt.c b/dlls/win32u/d3dkmt.c
index 38f7a53c3fb..a9c307c3211 100644
--- a/dlls/win32u/d3dkmt.c
+++ b/dlls/win32u/d3dkmt.c
@@ -748,6 +748,14 @@ NTSTATUS WINAPI NtGdiDdDDIQueryAdapterInfo( D3DKMT_QUERYADAPTERINFO *desc )
             data->HwSchSupported = 1;
             data->HwSchEnabledByDefault = 1;
         }
+        /* on multi GPU systems nvidia streamline may not properly detect hardware scheduling support.
+         * However, enabling it by default for all configurations may be risky. */
+        else if ((e = getenv( "WINE_ENABLE_HARDWARE_SCHEDULING" )) && *e == '1')
+        {
+            data->HwSchEnabled = 1;
+            data->HwSchSupported = 1;
+            data->HwSchEnabledByDefault = 1;
+        }
 
         return STATUS_SUCCESS;
     }
