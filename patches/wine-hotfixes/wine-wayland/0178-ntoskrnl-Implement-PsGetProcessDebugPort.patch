From 878d2deffe71ea9cb9ae78312c664db98dba893d Mon Sep 17 00:00:00 2001
From: Etaash Mathamsetty
 <45927311+Etaash-mathamsetty@users.noreply.github.com>
Date: Sun, 28 Jun 2026 20:48:33 -0400
Subject: [PATCH 178/185] ntoskrnl: Implement PsGetProcessDebugPort.

---
 dlls/ntoskrnl.exe/ntoskrnl.c         | 14 +++++++++++++-
 dlls/ntoskrnl.exe/ntoskrnl.exe.spec  |  2 +-
 dlls/ntoskrnl.exe/ntoskrnl_private.h |  1 +
 3 files changed, 15 insertions(+), 2 deletions(-)

diff --git a/dlls/ntoskrnl.exe/ntoskrnl.c b/dlls/ntoskrnl.exe/ntoskrnl.c
index 23338831c6f..3094e7771b1 100644
--- a/dlls/ntoskrnl.exe/ntoskrnl.c
+++ b/dlls/ntoskrnl.exe/ntoskrnl.c
@@ -2519,9 +2519,12 @@ static void *create_process_object( HANDLE handle )
         free(fullImageNameW);
     }
 
-    status = NtQueryInformationProcess( handle, ProcessWow64Information, &process->peb32, sizeof(process->peb32), 0);
+    status = NtQueryInformationProcess( handle, ProcessWow64Information, &process->peb32, sizeof(process->peb32), NULL );
     if (status) process->peb32 = NULL;
 
+    NtQueryInformationProcess( handle, ProcessDebugPort, &process->debug_port, sizeof(process->debug_port), NULL );
+    if (status) process->debug_port = 0;
+
     return process;
 }
 
@@ -2618,6 +2621,15 @@ const char *WINAPI PsGetProcessImageFileName( PEPROCESS process )
     return process->imageName;
 }
 
+/*********************************************************************
+ *           PsGetProcessDebugPort    (NTOSKRNL.@)
+ */
+DWORD_PTR WINAPI PsGetProcessDebugPort( PEPROCESS process )
+{
+    TRACE("%p\n", process);
+    return process->debug_port;
+}
+
 /*********************************************************************
  *           PsGetProcessExitStatus    (NTOSKRNL.@)
  */
diff --git a/dlls/ntoskrnl.exe/ntoskrnl.exe.spec b/dlls/ntoskrnl.exe/ntoskrnl.exe.spec
index c29cbe439ad..8eb204dc5d7 100644
--- a/dlls/ntoskrnl.exe/ntoskrnl.exe.spec
+++ b/dlls/ntoskrnl.exe/ntoskrnl.exe.spec
@@ -927,7 +927,7 @@
 @ stub PsGetJobSessionId
 @ stub PsGetJobUIRestrictionsClass
 @ stdcall PsGetProcessCreateTimeQuadPart(ptr)
-@ stub PsGetProcessDebugPort
+@ stdcall PsGetProcessDebugPort(ptr)
 @ stub PsGetProcessExitProcessCalled
 @ stdcall PsGetProcessExitStatus(ptr)
 @ stub PsGetProcessExitTime
diff --git a/dlls/ntoskrnl.exe/ntoskrnl_private.h b/dlls/ntoskrnl.exe/ntoskrnl_private.h
index cef1f935d6a..b735ebcb4c1 100644
--- a/dlls/ntoskrnl.exe/ntoskrnl_private.h
+++ b/dlls/ntoskrnl.exe/ntoskrnl_private.h
@@ -57,6 +57,7 @@ struct _EPROCESS
     PROCESS_BASIC_INFORMATION info;
     KERNEL_USER_TIMES times;
     PEB32 *peb32;
+    DWORD_PTR debug_port;
     ULONG session_id;
     char imageName[16];
 };
-- 
