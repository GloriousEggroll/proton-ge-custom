From db98b3501d145daea6a33d2b2971cf6d99d568c6 Mon Sep 17 00:00:00 2001
From: Etaash Mathamsetty
 <45927311+Etaash-mathamsetty@users.noreply.github.com>
Date: Mon, 1 Jun 2026 01:53:53 -0400
Subject: [PATCH 138/153] winewayland: Store geometry rect in wayland surface.

Also allows us to perform an optimization. Helps with xdg_popup implementation.
---
 dlls/winewayland.drv/wayland_surface.c | 4 +++-
 dlls/winewayland.drv/waylanddrv.h      | 1 +
 2 files changed, 4 insertions(+), 1 deletion(-)

diff --git a/dlls/winewayland.drv/wayland_surface.c b/dlls/winewayland.drv/wayland_surface.c
index fecd387e2f8..7156899fc92 100644
--- a/dlls/winewayland.drv/wayland_surface.c
+++ b/dlls/winewayland.drv/wayland_surface.c
@@ -673,6 +673,7 @@ void wayland_surface_clear_role(struct wayland_surface *surface)
 
     surface->content_width = 0;
     surface->content_height = 0;
+    SetRect(&surface->geometry, 0, 0, 0, 0);
 
     wl_display_flush(process_wayland.wl_display);
 }
@@ -843,12 +844,13 @@ static void wayland_surface_reconfigure_geometry(struct wayland_surface *surface
 
     TRACE("hwnd=%p geometry=%s\n", surface->hwnd, wine_dbgstr_rect(&rect));
 
-    if (!IsRectEmpty(&rect))
+    if (!IsRectEmpty(&rect) && !EqualRect(&surface->geometry, &rect))
     {
         int width = rect.right - rect.left, height = rect.bottom - rect.top;
         xdg_surface_set_window_geometry(surface->xdg_surface,
                                         rect.left, rect.top,
                                         width, height);
+        surface->geometry = rect;
         if (surface->window.resizeable)
         {
             xdg_toplevel_set_min_size(surface->xdg_toplevel, 0, 0);
diff --git a/dlls/winewayland.drv/waylanddrv.h b/dlls/winewayland.drv/waylanddrv.h
index 37571746fc0..4535935e607 100644
--- a/dlls/winewayland.drv/waylanddrv.h
+++ b/dlls/winewayland.drv/waylanddrv.h
@@ -412,6 +412,7 @@ struct wayland_surface
     struct wayland_surface_config pending, requested, processing, current;
     BOOL resizing;
     struct wayland_window_config window;
+    RECT geometry;
     int content_width, content_height;
     UINT32 alpha_multiplier;
     HCURSOR hcursor;
-- 
