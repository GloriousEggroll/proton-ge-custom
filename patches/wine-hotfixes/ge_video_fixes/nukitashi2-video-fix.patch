From: GE-Proton
Subject: [PATCH] Fix ASF video playback hang in qasf/winegstreamer/strmbase/quartz/wtsapi32

Eight bugs cause Nukitashi 2 (GOG) in-game movie files to hang:

1. qasf: media_seeking_ChangeCurrent flushes wrong pin on seek.
   The BeginFlush/EndFlush loops always used the pin from the single
   stream associated with the IMediaSeeking interface being called,
   instead of iterating all streams. Also missing NULL check on peer.
   Additionally, skip the flush entirely when the filter is stopped
   (seek position will be picked up by filter_init_stream on transition).

2. qasf: allocators not recommitted after seek flush.
   After BeginFlush/EndFlush, the downstream decoder may have decommitted
   its allocator. ChangeCurrent did not recommit before restarting the
   reader, causing IMemAllocator_GetBuffer to return VFW_E_NOT_COMMITTED,
   which propagated as NS_E_NO_MORE_SAMPLES and falsely signaled EOS.

3. winegstreamer: wm_reader_read_stream_sample returns NS_E_NO_MORE_SAMPLES
   on allocation failure. The async reader treats NS_E_NO_MORE_SAMPLES as a
   real end-of-stream and sends WMT_END_OF_STREAMING + WMT_EOF. The actual
   HRESULT should be propagated so the failure is handled correctly.

4. winegstreamer: stale current_buffer after seek causes assertion crash.
   reader_SetRange performs a GStreamer seek that flushes all GStreamer
   buffers, but stream->current_buffer (left from a partial audio read
   in progress at seek time) is never cleared. On restart, the read thread
   reuses the stale buffer size against a new (possibly smaller) mapped
   GStreamer buffer, triggering the assertion in wg_parser_stream_copy_buffer.
   Fix: call free_stream_buffers() before the GStreamer seek.

5. qasf: AllocateForOutput has insufficient diagnostics for NOT_CONNECTED.
   Add ERR-level diagnostics to identify the output index and stream_count
   so the root cause of the NOT_CONNECTED failure can be determined.

6. strmbase: renderer_init_stream returns S_FALSE causing async Run path.
   When IMediaControl::Run is called on a graph in Stopped state, the filter
   graph manager calls IBaseFilter::Pause on each filter. The strmbase
   renderer's filter_init_stream returns S_FALSE when the sink pin is
   connected. This S_FALSE triggers the async threadpool path in
   MediaControl_Run. If the application calls Stop before the async callback
   runs, graph_start is never called and the video never plays.
   Fix: renderer_init_stream returns S_OK unconditionally.

7. quartz: dsound_render_init_stream returns S_FALSE causing async Run path.
   Same root cause as bug #6 but in a separate code path in dsoundrender.c.
   Fix: return S_OK unconditionally.

8. wtsapi32: WTSUnRegisterSessionNotificationEx returns FALSE while
   WTSRegisterSessionNotificationEx returns TRUE. Fixed to return TRUE.

diff --git a/dlls/qasf/asfreader.c b/dlls/qasf/asfreader.c
index 46a3d7e45d5..0cb5903e086 100644
--- a/dlls/qasf/asfreader.c
+++ b/dlls/qasf/asfreader.c
@@ -332,10 +332,17 @@ static HRESULT WINAPI media_seeking_ChangeCurrent(IMediaSeeking *iface)
 
     TRACE("iface %p.\n", iface);
 
+    /* If the filter is stopped, just update the seek position and return.
+     * The reader will be started from the new position when the filter
+     * transitions to running/paused via filter_init_stream. */
+    if (filter->filter.state == State_Stopped)
+        return S_OK;
+
     /* Send begin flush commands downstream. */
     for (i = 0; i < filter->stream_count; ++i)
     {
-        if (FAILED(IPin_BeginFlush(stream->source.pin.peer)))
+        if (filter->streams[i].source.pin.peer &&
+                FAILED(IPin_BeginFlush(filter->streams[i].source.pin.peer)))
             WARN("Failed to BeginFlush for stream %u.\n", i);
     }
 
@@ -345,10 +352,23 @@ static HRESULT WINAPI media_seeking_ChangeCurrent(IMediaSeeking *iface)
     /* Send end flush commands downstream. */
     for (i = 0; i < filter->stream_count; ++i)
     {
-        if (FAILED(IPin_EndFlush(stream->source.pin.peer)))
+        if (filter->streams[i].source.pin.peer &&
+                FAILED(IPin_EndFlush(filter->streams[i].source.pin.peer)))
             WARN("Failed to EndFlush for stream %u.\n", i);
     }
 
+    /* Recommit allocators; the downstream filter may have decommitted them
+     * in response to BeginFlush. */
+    for (i = 0; i < filter->stream_count; ++i)
+    {
+        struct asf_stream *s = filter->streams + i;
+
+        if (!s->source.pin.peer)
+            continue;
+        if (FAILED(IMemAllocator_Commit(s->source.pAllocator)))
+            WARN("Failed to recommit stream %u allocator after flush.\n", i);
+    }
+
     /* Start the reader. */
     if (hr == S_OK)
         hr = asf_reader_start_stream(filter, seek->llCurrent, seek->llDuration, seek->dRate);
@@ -566,8 +586,12 @@ static HRESULT asf_reader_init_stream(struct strmbase_filter *iface)
     if (FAILED(hr))
         return hr;
 
-    if (FAILED(hr = asf_reader_start_stream(filter, 0, 0, 1.0)))
-        WARN("Failed to start WMReader %p, hr %#lx\n", filter->reader, hr);
+    {
+        LONGLONG start = filter->streams[0].seek.llCurrent;
+        float rate = (float)filter->streams[0].seek.dRate;
+        if (FAILED(hr = asf_reader_start_stream(filter, start, 0, rate)))
+            WARN("Failed to start WMReader %p, hr %#lx\n", filter->reader, hr);
+    }
 
     return hr;
 }
@@ -583,6 +607,13 @@ static HRESULT asf_reader_cleanup_stream(struct strmbase_filter *iface)
     if (FAILED(hr = asf_reader_stop_stream(filter)))
         WARN("Failed to stop WMReader %p, hr %#lx\n", filter->reader, hr);
 
+    for (i = 0; i < filter->stream_count; ++i)
+    {
+        struct asf_stream *stream = filter->streams + i;
+        if (stream->source.pin.peer)
+            IPin_EndOfStream(stream->source.pin.peer);
+    }
+
     for (i = 0; i < filter->stream_count; ++i)
     {
         struct asf_stream *stream = filter->streams + i;
@@ -1041,8 +1072,18 @@ static HRESULT WINAPI reader_callback_advanced_AllocateForOutput(IWMReaderCallba
 
     *out = NULL;
 
+    if (output >= filter->stream_count)
+    {
+        ERR("Output %lu out of range (stream_count %u).\n", output, filter->stream_count);
+        return VFW_E_NOT_CONNECTED;
+    }
+
     if (!stream->source.pin.peer)
+    {
+        ERR("Stream %lu pin not connected (stream_count %u).\n",
+                output, filter->stream_count);
         return VFW_E_NOT_CONNECTED;
+    }
 
     if (FAILED(hr = IMemAllocator_GetBuffer(stream->source.pAllocator, &sample, NULL, NULL, 0)))
     {
diff --git a/dlls/quartz/dsoundrender.c b/dlls/quartz/dsoundrender.c
index e72b743e39e..d7f2c05ad08 100644
--- a/dlls/quartz/dsoundrender.c
+++ b/dlls/quartz/dsoundrender.c
@@ -675,7 +675,7 @@ static HRESULT dsound_render_init_stream(struct strmbase_filter *iface)
     if (!(filter->render_thread = CreateThread(NULL, 0, render_thread_run, filter, 0, NULL)))
         return HRESULT_FROM_WIN32(GetLastError());
 
-    return S_FALSE;
+    return S_OK;
 }
 
 static HRESULT dsound_render_start_stream(struct strmbase_filter *iface, REFERENCE_TIME start)
diff --git a/dlls/winegstreamer/wm_reader.c b/dlls/winegstreamer/wm_reader.c
index 0b5651fc7f7..791dde9911a 100644
--- a/dlls/winegstreamer/wm_reader.c
+++ b/dlls/winegstreamer/wm_reader.c
@@ -1885,7 +1885,7 @@ static HRESULT wm_reader_read_stream_sample(struct wm_reader *reader, struct wg_
     {
         ERR("Failed to allocate sample of %lu bytes, hr %#lx.\n", capacity, hr);
         wg_parser_stream_release_buffer(stream->wg_stream);
-        return NS_E_NO_MORE_SAMPLES;
+        return hr;
     }
 
     if (FAILED(hr = INSSBuffer_GetBufferAndLength(*sample, &data, &size)))
@@ -2627,6 +2627,8 @@ static HRESULT WINAPI reader_SetRange(IWMSyncReader2 *iface, QWORD start, LONGLO
 
     reader->start_time = start;
 
+    free_stream_buffers(reader);
+
     wg_parser_stream_seek(reader->streams[0].wg_stream, 1.0, start, start + duration,
             AM_SEEKING_AbsolutePositioning, duration ? AM_SEEKING_AbsolutePositioning : AM_SEEKING_NoPositioning);
 
diff --git a/dlls/wtsapi32/wtsapi32.c b/dlls/wtsapi32/wtsapi32.c
index 5a1a87f416e..51db5f16b40 100644
--- a/dlls/wtsapi32/wtsapi32.c
+++ b/dlls/wtsapi32/wtsapi32.c
@@ -796,7 +796,7 @@ BOOL WINAPI WTSUnRegisterSessionNotification(HWND hWnd)
 BOOL WINAPI WTSUnRegisterSessionNotificationEx(HANDLE hServer, HWND hWnd)
 {
     FIXME("Stub %p %p\n", hServer, hWnd);
-    return FALSE;
+    return TRUE;
 }
 
 
diff --git a/libs/strmbase/renderer.c b/libs/strmbase/renderer.c
index dc421f499ed..3f0861d50e2 100644
--- a/libs/strmbase/renderer.c
+++ b/libs/strmbase/renderer.c
@@ -236,7 +236,7 @@ static HRESULT renderer_init_stream(struct strmbase_filter *iface)
     if (filter->ops->renderer_init_stream)
         filter->ops->renderer_init_stream(filter);
 
-    return filter->sink.pin.peer ? S_FALSE : S_OK;
+    return S_OK;
 }
 
 static HRESULT renderer_start_stream(struct strmbase_filter *iface, REFERENCE_TIME start)
